# ---------------------------------------------------------------- output

GREEN, RED, YELLOW, DIM, CYAN, BOLD = "32", "31", "33", "2", "36", "1"


_TTY = None


def _tty():
    # cached from the REAL stdout on first use, so buffered rendering
    # (watch double-buffers a frame through StringIO) keeps its colors
    global _TTY
    if _TTY is None:
        _TTY = sys.stdout.isatty()
    return _TTY


def paint(s, code):
    if _tty():
        return "\033[{}m{}\033[0m".format(code, s)
    return s


def info(msg):
    print(paint("::", CYAN) + " " + msg)


def ok(msg):
    print(paint("ok", GREEN) + " " + msg)


def warn(msg):
    print(paint("!!", YELLOW) + " " + msg, file=sys.stderr)


def run(cmd, cwd=None, check=False):
    p = subprocess.run(cmd, cwd=cwd, stdout=subprocess.PIPE,
                       stderr=subprocess.STDOUT, universal_newlines=True)
    if check and p.returncode != 0:
        raise Err("command failed ({}): {}\n{}".format(
            p.returncode, " ".join(cmd), (p.stdout or "").strip()))
    return p


# ---------------------------------------------------------------- TOML

def _strip_comment(s):
    out, instr, q = [], False, ""
    for ch in s:
        if instr:
            out.append(ch)
            if ch == q:
                instr = False
        elif ch in "\"'":
            instr, q = True, ch
            out.append(ch)
        elif ch == "#":
            break
        else:
            out.append(ch)
    return "".join(out).strip()


def _parse_val(s):
    s = s.strip()
    if s.startswith("["):
        if not s.endswith("]"):
            raise ValueError("arrays must be on one line: " + s)
        inner = s[1:-1].strip()
        if not inner:
            return []
        items, buf, instr, q = [], "", False, ""
        for ch in inner:
            if instr:
                buf += ch
                if ch == q:
                    instr = False
            elif ch in "\"'":
                instr, q = True, ch
                buf += ch
            elif ch == ",":
                items.append(buf.strip())
                buf = ""
            else:
                buf += ch
        if buf.strip():
            items.append(buf.strip())
        return [_parse_val(x) for x in items]
    if (s.startswith('"') and s.endswith('"')) or (s.startswith("'") and s.endswith("'")):
        return s[1:-1]
    if s == "true":
        return True
    if s == "false":
        return False
    try:
        return int(s)
    except ValueError:
        raise ValueError("unquoted value: " + s)


def _parse_toml_min(text):
    """Minimal TOML subset: [tables] (incl. dotted names), strings, ints,
    bools, one-line string arrays."""
    root = {}
    cur = root
    for lineno, raw in enumerate(text.splitlines(), 1):
        line = _strip_comment(raw.strip())
        if not line:
            continue
        if line.startswith("[") and line.endswith("]"):
            cur = root
            for part in line[1:-1].strip().split("."):
                cur = cur.setdefault(part.strip(), {})
            continue
        if "=" not in line:
            raise ValueError("line {}: expected key = value".format(lineno))
        key, val = line.split("=", 1)
        try:
            cur[key.strip()] = _parse_val(val)
        except ValueError as e:
            raise ValueError("line {}: {}".format(lineno, e))
    return root


try:
    import tomllib

    def parse_toml(text):
        return tomllib.loads(text)
except ImportError:
    parse_toml = _parse_toml_min


# ---------------------------------------------------------------- config model

class Pool:
    def __init__(self, data, name, instance):
        for k, v in data.items():
            setattr(self, k, v)
        self.name = name
        self.instance = instance


class Instance:
    def __init__(self, name, path):
        self.name = name
        self.path = path
        self.as_host = None
        self.check_updates = "ask"
        self.pools = OrderedDict()

    @property
    def single(self):
        return len(self.pools) == 1

    def only_pool(self):
        return next(iter(self.pools.values()))

    def local_pools(self):
        return [p for p in self.pools.values() if not p.host]

    def remote_hosts(self):
        out = OrderedDict()
        for p in self.pools.values():
            if p.host:
                out.setdefault(p.host, []).append(p)
        return out


def find_config(explicit):
    candidates = []
    if explicit:
        candidates.append(explicit)
    if os.environ.get("RUNNERCTL_CONFIG"):
        candidates.append(os.environ["RUNNERCTL_CONFIG"])
    candidates.append("runners.toml")
    candidates.append(os.path.expanduser("~/.config/runnerctl/runners.toml"))
    for c in candidates:
        if os.path.isfile(c):
            return c
    raise Err("no runners.toml found (searched: {})\nrun `runnerctl init` to create one".format(
        ", ".join(candidates)))


def split_url(url):
    m = re.match(r"https?://github\.com/([^/\s]+?)(?:/([^/\s]+?))?/?$", url.strip())
    if not m:
        raise Err("unsupported url {!r}: expected https://github.com/<org> "
                  "or https://github.com/<owner>/<repo>".format(url))
    return m.group(1), m.group(2)


def api_scope(url):
    owner, repo = split_url(url)
    if repo:
        return "repos/{}/{}".format(owner, repo)
    return "orgs/{}".format(owner)


_NAME_RE = re.compile(r"[A-Za-z0-9_-]+$")


def _finalize_local_paths(data):
    # only meaningful on the machine the pool actually runs on: "~" must
    # expand with THAT machine's home, so remote pools keep the raw string
    data["base_dir"] = os.path.abspath(os.path.expanduser(str(data["base_dir"])))


def load_config(path):
    with open(path) as f:
        text = f.read()
    try:
        doc = parse_toml(text)
    except Exception as e:
        raise Err("cannot parse {}: {}".format(path, e))

    raw_schema = doc.get("config_version")
    if raw_schema is not None and not isinstance(raw_schema, dict):
        if isinstance(raw_schema, bool) or isinstance(raw_schema, float):
            raise Err('{}: config_version must be a string like "1.0"'.format(path))
        if isinstance(raw_schema, int):
            file_schema = (raw_schema, 0)
        else:
            m = re.match(r"(\d+)(?:\.(\d+))?$", str(raw_schema).strip())
            if not m:
                raise Err('{}: config_version must look like "1.0"'.format(path))
            file_schema = (int(m.group(1)), int(m.group(2) or 0))
        if file_schema[0] != CONFIG_SCHEMA[0]:
            hint = ("run `runnerctl update`" if file_schema[0] > CONFIG_SCHEMA[0]
                    else "migrate the config or use an older runnerctl")
            raise Err("{}: config_version {}.{} is incompatible with this "
                      "runnerctl (schema {}.{}) — {}".format(
                          path, file_schema[0], file_schema[1],
                          CONFIG_SCHEMA[0], CONFIG_SCHEMA[1], hint))
        if file_schema[1] > CONFIG_SCHEMA[1]:
            warn("{}: config schema {}.{} is newer than this runnerctl "
                 "(schema {}.{}); some keys may be ignored — consider "
                 "`runnerctl update`".format(path, file_schema[0], file_schema[1],
                                             CONFIG_SCHEMA[0], CONFIG_SCHEMA[1]))
        elif file_schema[1] < CONFIG_SCHEMA[1]:
            warn("{}: config written for older schema {}.{} (current {}.{}); "
                 "still compatible".format(path, file_schema[0], file_schema[1],
                                           CONFIG_SCHEMA[0], CONFIG_SCHEMA[1]))
    defaults_tbl = doc.get("defaults", {})
    if not isinstance(defaults_tbl, dict):
        raise Err("{}: [defaults] must be a table".format(path))
    pool_tbl = doc.get("pool", {})
    if not isinstance(pool_tbl, dict):
        raise Err("{}: [pool] must be a table".format(path))
    subtables = OrderedDict((k, v) for k, v in pool_tbl.items() if isinstance(v, dict))
    scalars = {k: v for k, v in pool_tbl.items() if not isinstance(v, dict)}
    if subtables and scalars:
        raise Err("{}: [pool] mixes direct keys with [pool.<name>] tables; "
                  "move shared keys into [defaults]".format(path))
    if subtables:
        pools_raw = subtables
    elif scalars:
        pools_raw = OrderedDict([("default", scalars)])
    else:
        raise Err("{}: define a [pool] section or one or more [pool.<name>] "
                  "tables".format(path))

    # instance-level keys: top level < [defaults] < single anonymous [pool]
    inst_data = dict(INSTANCE_DEFAULTS)
    sources = [doc, defaults_tbl] + ([scalars] if scalars else [])
    for src in sources:
        for k in INSTANCE_DEFAULTS:
            if k in src and not isinstance(src[k], dict):
                inst_data[k] = src[k]
    inst_name = str(inst_data["name"])
    if not _NAME_RE.match(inst_name):
        raise Err("{}: name must be alphanumeric/dash/underscore".format(path))
    if inst_data["check_updates"] not in ("ask", "always", "never"):
        raise Err('{}: check_updates must be "ask", "always" or "never"'.format(path))
    inst = Instance(inst_name, path)
    inst.check_updates = inst_data["check_updates"]

    # manager is a pool key ([defaults]-inheritable) since each MACHINE hosts
    # its own supervisor; a bare top-level `manager` acts as a global default
    top_manager = doc.get("manager") if not isinstance(doc.get("manager"), dict) else None

    known_top = {"pool", "defaults", "manager", "config_version"} | set(INSTANCE_DEFAULTS)
    unknown_top = sorted(k for k in doc if k not in known_top)
    if unknown_top:
        warn("{}: ignoring unknown key(s): {}".format(path, ", ".join(unknown_top)))
    unknown_def = sorted(set(defaults_tbl) - set(POOL_DEFAULTS) - set(INSTANCE_DEFAULTS))
    if unknown_def:
        warn("{}: [defaults] ignoring unknown key(s): {}".format(path, ", ".join(unknown_def)))

    hostname = socket.gethostname().split(".")[0]
    seen_dirs = {}
    for pname, raw in pools_raw.items():
        if not _NAME_RE.match(pname):
            raise Err("{}: pool name {!r} must be alphanumeric/dash/underscore".format(
                path, pname))
        unknown = sorted(set(raw) - set(POOL_DEFAULTS) - set(INSTANCE_DEFAULTS))
        if unknown:
            warn("{}: [pool.{}] ignoring unknown key(s): {}".format(
                path, pname, ", ".join(unknown)))
        data = dict(POOL_DEFAULTS)
        if top_manager is not None:
            data["manager"] = top_manager
        data.update({k: v for k, v in defaults_tbl.items() if k in POOL_DEFAULTS})
        data.update({k: v for k, v in raw.items() if k in POOL_DEFAULTS})
        where = "[pool]" if pname == "default" and scalars else "[pool.{}]".format(pname)
        if data["manager"] not in ("auto", "systemd", "nohup"):
            raise Err('{}: {}: manager must be "auto", "systemd" or "nohup"'.format(
                path, where))
        if not data["url"] or "YOUR-ORG" in data["url"]:
            raise Err("{}: set `url` in {} (or [defaults])".format(path, where))
        api_scope(data["url"])  # validate shape early
        if not isinstance(data["count"], int) or data["count"] < 0:
            raise Err("{}: {}: count must be a non-negative integer".format(path, where))
        if isinstance(data["labels"], str):
            data["labels"] = [data["labels"]]
        if not data["labels"] or not all(isinstance(x, str) for x in data["labels"]):
            raise Err("{}: {}: labels must be a non-empty list of strings".format(path, where))
        data["host"] = str(data["host"]).strip()
        if data["host"] and not re.match(r"(?:[\w.-]+@)?[\w.-]+$", data["host"]):
            raise Err("{}: {}: host must be an ssh destination like "
                      "user@node.example.org (or an ssh alias)".format(path, where))
        data["version"] = str(data["version"])
        if not data["name_prefix"]:
            # remote pools default to the host's slug so both the control
            # machine and the remote agent derive identical runner names
            data["name_prefix"] = host_slug(data["host"]) if data["host"] else hostname
        if not data["dir_prefix"]:
            data["dir_prefix"] = "runner" if pname == "default" else pname
        if not data["host"]:
            _finalize_local_paths(data)
        key = (data["host"], str(data["base_dir"]), data["dir_prefix"])
        if key in seen_dirs:
            raise Err("{}: pools {!r} and {!r} share base_dir {} with the same "
                      "dir_prefix {!r} on the same host".format(
                          path, seen_dirs[key], pname, key[1], key[2]))
        crosshost = (str(data["base_dir"]), data["dir_prefix"])
        for (h, b, d), other in list(seen_dirs.items()):
            if h != data["host"] and (b, d) == crosshost:
                warn("{}: pools {!r} ({}) and {!r} ({}) use the same base_dir "
                     "and dir_prefix on different hosts — if those hosts share "
                     "a home directory, give each pool a distinct dir_prefix".format(
                         path, other, h or "local", pname, data["host"] or "local"))
        seen_dirs[key] = pname
        inst.pools[pname] = Pool(data, pname, inst)
    by_host = {}
    for p in inst.pools.values():
        by_host.setdefault(p.host, set()).add(p.manager)
    for h, managers in by_host.items():
        if len(managers) > 1:
            raise Err("{}: pools on {} disagree on manager ({}) — one machine "
                      "runs one supervisor".format(
                          path, h or "this machine", ", ".join(sorted(managers))))
    return inst


def local_manager(inst):
    for p in inst.local_pools():
        return p.manager
    return "auto"


def scope_instance(inst, host):
    """--as-host: keep only pools assigned to `host` and treat them as local
    (this process IS that host). Used by remote agents and their daemons."""
    scoped = OrderedDict()
    for name, p in inst.pools.items():
        if p.host == host:
            p.host = ""
            data = {"base_dir": p.base_dir}
            _finalize_local_paths(data)
            p.base_dir = data["base_dir"]
            scoped[name] = p
    if not scoped:
        raise Err("no pools assigned to host {!r} in {}".format(host, inst.path))
    inst.pools = scoped
    inst.as_host = host
    return inst


# ---------------------------------------------------------------- GitHub

_TOKEN_CACHE = []


def get_token():
    if _TOKEN_CACHE:
        return _TOKEN_CACHE[0]
    tok = None
    for var in ("GITHUB_TOKEN", "GH_TOKEN"):
        if os.environ.get(var):
            tok = os.environ[var].strip()
            break
    if tok is None and shutil.which("gh"):
        p = run(["gh", "auth", "token"])
        if p.returncode == 0 and (p.stdout or "").strip():
            tok = p.stdout.strip().splitlines()[-1]
    _TOKEN_CACHE.append(tok)
    return tok


def api(method, path, token, body=None):
    url = path if path.startswith("http") else "{}/{}".format(API_ROOT, path)
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Accept", "application/vnd.github+json")
    req.add_header("X-GitHub-Api-Version", "2022-11-28")
    req.add_header("User-Agent", "runnerctl")
    if token:
        req.add_header("Authorization", "Bearer " + token)
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            raw = resp.read()
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", "replace")
        try:
            detail = json.loads(detail).get("message", detail)
        except ValueError:
            pass
        raise Err("GitHub API {} {} -> HTTP {}: {}".format(method, path, e.code, detail))
    except urllib.error.URLError as e:
        raise Err("GitHub API unreachable: {}".format(e.reason))
    if not raw:
        return {}
    return json.loads(raw.decode("utf-8"))


class GitHub:
    """Token acquisition ladder: pre-supplied tokens (piped over ssh stdin by
    a control machine) -> GITHUB_TOKEN/GH_TOKEN -> gh CLI -> interactive
    prompt. With an API token, registration/removal tokens are minted
    automatically and remote runner status is available. Pre-supplied tokens
    allow a remote agent to register/deregister without ever seeing the
    GitHub token itself."""

    def __init__(self, pool):
        self.pool = pool
        self.scope = api_scope(pool.url)
        self.env_reg = os.environ.get("RUNNERCTL_REG_TOKEN") or None
        self.env_rem = os.environ.get("RUNNERCTL_REM_TOKEN") or None
        self.token = get_token()
        self._reg = None
        self._rem = None
        self._reg_cache = (None, 0.0)
        self._rem_cache = (None, 0.0)
        self._warned = False

    @property
    def manual(self):
        return self.token is None

    def warn_manual(self, what):
        if AGENT_MODE or self.env_reg or self.env_rem:
            return  # the control machine already handled/checked this
        if not self._warned:
            warn("no GitHub token (GITHUB_TOKEN / `gh auth login`): {}".format(what))
            self._warned = True

    def _settings_page(self):
        owner, repo = split_url(self.pool.url)
        if repo:
            return "https://github.com/{}/{}/settings/actions/runners".format(owner, repo)
        return "https://github.com/organizations/{}/settings/actions/runners".format(owner)

    def _prompt(self, kind, page):
        if not sys.stdin.isatty():
            raise Err("no GitHub token and stdin is not a terminal; "
                      "set GITHUB_TOKEN or run interactively")
        self.warn_manual("switching to manually pasted tokens")
        print()
        info("open:  {}".format(page))
        info("copy the value shown after --token in the {} command".format(kind))
        try:
            val = input("paste {} token (empty aborts): ".format(kind)).strip()
        except EOFError:
            val = ""
        print()
        if not val:
            raise Err("aborted: no {} token provided".format(kind))
        return val

    def _minted(self, cache, kind, refresh):
        """API-minted tokens last ~1h: mint once, reuse across a whole
        up/rm pass instead of one API call per runner."""
        value, good_until = cache
        if refresh or value is None or time.time() > good_until:
            value = api("POST", "{}/actions/runners/{}-token".format(self.scope, kind),
                        self.token)["token"]
            good_until = time.time() + 45 * 60
        return value, (value, good_until)

    def reg_token(self, refresh=False):
        if self.env_reg:
            if refresh:
                raise Err("the supplied registration token was rejected")
            return self.env_reg
        if self.manual:
            if self._reg is None or refresh:
                self._reg = self._prompt("registration", self._settings_page() + "/new")
            return self._reg
        token, self._reg_cache = self._minted(self._reg_cache, "registration", refresh)
        return token

    def rem_token(self, refresh=False):
        if self.env_rem:
            if refresh:
                raise Err("the supplied removal token was rejected")
            return self.env_rem
        if self.manual:
            if self._rem is None or refresh:
                self._rem = self._prompt("removal", self._settings_page())
            return self._rem
        token, self._rem_cache = self._minted(self._rem_cache, "remove", refresh)
        return token

    def runners(self):
        """name -> API entry for every runner registered at this scope."""
        if self.manual:
            return {}
        out, page = {}, 1
        while True:
            r = api("GET", "{}/actions/runners?per_page=100&page={}".format(self.scope, page),
                    self.token)
            batch = r.get("runners", [])
            for x in batch:
                out[x.get("name")] = x
            if len(batch) < 100:
                break
            page += 1
        return out

    def delete_runner(self, runner_id):
        api("DELETE", "{}/actions/runners/{}".format(self.scope, runner_id), self.token)


class GitHubSessions:
    """One GitHub session per pool, one remote listing per distinct scope."""

    def __init__(self):
        self._by_pool = {}
        self._remote_by_scope = {}

    def for_pool(self, pool):
        if pool.name not in self._by_pool:
            self._by_pool[pool.name] = GitHub(pool)
        return self._by_pool[pool.name]

    def remote(self, pool):
        gh = self.for_pool(pool)
        if gh.scope not in self._remote_by_scope:
            self._remote_by_scope[gh.scope] = gh.runners()
        return self._remote_by_scope[gh.scope]

    def busy(self, pool, purpose):
        gh = self.for_pool(pool)
        if gh.manual:
            gh.warn_manual("cannot check busy state before {}".format(purpose))
            return {}
        try:
            return {n: e for n, e in self.remote(pool).items() if e.get("busy")}
        except Err as e:
            warn(str(e))
            return {}


# ---------------------------------------------------------------- ssh transport

class RemoteHost:
    """Drives one ssh host: deploys this script + the config (a single tar
    stream over ssh, no scp), invokes remote runnerctl with --as-host, and
    pipes short-lived tokens over stdin so nothing secret hits argv or disk."""

    def __init__(self, host):
        self.host = host
        self._deployed = False
        self._state = None

    def _paths(self, inst):
        return (REMOTE_BASE + "/runnerctl",
                REMOTE_BASE + "/{}.toml".format(inst.name))

    def _ssh(self, remote_cmd, stdin_bytes=None, timeout=600, stream=False):
        cmd = ["ssh", "-o", "BatchMode=yes", self.host, "--", remote_cmd]
        try:
            if not stream:
                return subprocess.run(cmd, input=stdin_bytes,
                                      stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                                      timeout=timeout)
            # live mode: print each remote line as it arrives so the user sees
            # downloads/registrations happening instead of a silent wait
            proc = subprocess.Popen(cmd, stdin=subprocess.PIPE,
                                    stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
            try:
                if stdin_bytes:
                    proc.stdin.write(stdin_bytes)
                proc.stdin.close()
            except BrokenPipeError:
                pass
            tag = paint("[{}]".format(self.host), DIM)
            lines = []
            for raw in iter(proc.stdout.readline, b""):
                line = raw.decode("utf-8", "replace").rstrip("\n")
                lines.append(line)
                print("  {} {}".format(tag, line), flush=True)
            proc.stdout.close()
            proc.wait()
            out = ("\n".join(lines) + "\n").encode() if lines else b""
            return subprocess.CompletedProcess(cmd, proc.returncode, out, b"")
        except subprocess.TimeoutExpired:
            raise Err("ssh to {} timed out".format(self.host))
        except FileNotFoundError:
            raise Err("ssh not found on this machine")

    def deploy(self, inst):
        if self._deployed:
            return
        info("deploying runnerctl to {} ...".format(self.host))
        script_path = os.path.realpath(os.path.abspath(sys.argv[0]))
        with open(script_path, "rb") as f:
            script = f.read()
        with open(inst.path, "rb") as f:
            conf = f.read()
        buf = io.BytesIO()
        with tarfile.open(fileobj=buf, mode="w") as tf:
            for name, data, mode in (("runnerctl", script, 0o755),
                                     ("{}.toml".format(inst.name), conf, 0o644)):
                ti = tarfile.TarInfo(name)
                ti.size = len(data)
                ti.mode = mode
                ti.mtime = int(time.time())
                tf.addfile(ti, io.BytesIO(data))
        cmd = 'mkdir -p "{0}" && tar -xf - -C "{0}"'.format(REMOTE_BASE)
        p = self._ssh(cmd, stdin_bytes=buf.getvalue(), timeout=60)
        if p.returncode != 0:
            raise Err("deploy to {} failed: {}".format(
                self.host, (p.stderr or b"").decode("utf-8", "replace").strip()))
        self._deployed = True

    def invoke(self, inst, args, tokens=None, deploy=True, stream=False):
        """Run remote runnerctl. `args` may start with extra global flags
        (e.g. --only). tokens = (reg, rem) piped via stdin, never argv.
        stream=True prints remote output live (already host-tagged), so
        callers must not relay it again."""
        if deploy:
            self.deploy(inst)
        script, conf = self._paths(inst)
        argv = ['"{}"'.format(script), "-c", '"{}"'.format(conf),
                "--as-host", shlex.quote(self.host), "--agent"]
        stdin = None
        if tokens is not None:
            argv.append("--tokens-stdin")
            stdin = "{}\n{}\n".format(tokens[0] or "", tokens[1] or "").encode()
        argv += [shlex.quote(str(a)) for a in args]
        p = self._ssh(" ".join(argv), stdin_bytes=stdin, stream=stream)
        out = (p.stdout or b"").decode("utf-8", "replace")
        errout = (p.stderr or b"").decode("utf-8", "replace")
        if p.returncode == 255:
            raise Err("ssh to {} failed: {}".format(
                self.host, errout.strip() or "connection error"))
        return p.returncode, out, errout

    def state(self, inst, deploy=True):
        """Fetch daemon + runner state as JSON from the remote agent."""
        if self._state is not None:
            return self._state
        rc, out, errout = self.invoke(inst, ["agent-status"], deploy=deploy)
        if rc == 127:
            raise Err("runnerctl is not deployed on {} yet "
                      "(`runnerctl up` deploys it)".format(self.host))
        if rc != 0:
            raise Err("agent-status on {} failed: {}".format(
                self.host, (errout or out).strip()))
        try:
            self._state = json.loads(out.strip().splitlines()[-1])
        except (ValueError, IndexError):
            raise Err("agent-status on {} returned garbage: {!r}".format(
                self.host, out[:200]))
        return self._state


def remote_hosts_for(inst):
    return OrderedDict((h, RemoteHost(h)) for h in inst.remote_hosts())


def pool_indices_map(inst, rhosts):
    """pool name -> sorted registered indices (None if its host is
    unreachable). The oracle for CLI ref expansion and validation."""
    out = {}
    for pool in inst.pools.values():
        if not pool.host:
            out[pool.name] = [i for i in local_indices(pool) if registered_name(pool, i)]
            continue
        try:
            st = rhosts[pool.host].state(inst, deploy=False)
            pl = st.get("pools", {}).get(pool.name, {})
            out[pool.name] = sorted(int(k) for k, v in pl.items() if v.get("name"))
        except Err:
            out[pool.name] = None
    return out


# ---------------------------------------------------------------- local pool state

def runner_dir(pool, i):
    return os.path.join(pool.base_dir, "{}{}".format(pool.dir_prefix, i))


def host_slug(host):
    """A filesystem/systemd-safe machine name from an ssh destination:
    'user@node1.example.org' -> 'node1'. The '@' must never reach a systemd
    unit name (it is the template separator) and runner names dislike it."""
    bare = host.split("@", 1)[-1]
    first = bare.split(".")[0]
    if first.isdigit():  # IP address: the first octet is no identity
        return re.sub(r"[^A-Za-z0-9_-]", "-", bare).strip("-")
    short = re.sub(r"[^A-Za-z0-9_-]", "-", first).strip("-")
    return short or re.sub(r"[^A-Za-z0-9_-]", "-", bare).strip("-")


def machine_id(inst):
    """This machine's identity for state/unit scoping: the slug of the
    --as-host destination on a remote agent, the local hostname on the
    control machine. Keeps clusters with SHARED home directories safe —
    every machine gets its own state and unit even though they see the
    same files."""
    if inst.as_host:
        return host_slug(inst.as_host)
    return socket.gethostname().split(".")[0]


def state_dir(inst):
    # scoped per instance AND per machine: on shared-home clusters several
    # supervisors (one per host) coexist under one physical ~/.local/state
    root = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return os.path.join(root, "runnerctl", inst.name, machine_id(inst))


def daemon_pidfile(inst):
    return os.path.join(state_dir(inst), "daemon.pid")


def daemon_logfile(inst):
    return os.path.join(state_dir(inst), "daemon.log")


def child_pidfile(pool, i):
    return os.path.join(state_dir(pool.instance), "pids",
                        "{}-{}.pid".format(pool.name, i))


def disabled_marker(pool, i):
    return os.path.join(state_dir(pool.instance), "disabled",
                        "{}-{}".format(pool.name, i))


def runner_logfile(pool, i):
    return os.path.join(runner_dir(pool, i), "runner.log")


def read_pid(path):
    try:
        with open(path) as f:
            return int(f.read().strip())
    except (OSError, ValueError):
        return None


def pid_alive(pid):
    if pid is None:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def kill_process_group(pid):
    """Graceful escalation against an EXTERNAL process group (pgid == pid).
    Only for processes that are not our children — a supervisor must reap its
    own children via wait(), since zombies still pass the kill-0 probe."""
    for sig, patience in ((signal.SIGINT, 30), (signal.SIGTERM, 10), (signal.SIGKILL, 5)):
        try:
            os.killpg(pid, sig)
        except ProcessLookupError:
            return
        deadline = time.time() + patience
        while time.time() < deadline and pid_alive(pid):
            time.sleep(0.5)
        if not pid_alive(pid):
            return


def registered_name(pool, i):
    path = os.path.join(runner_dir(pool, i), ".runner")
    if not os.path.isfile(path):
        return None
    try:
        with open(path, encoding="utf-8-sig") as f:
            return json.load(f).get("agentName")
    except (ValueError, OSError):
        return None


def local_indices(pool):
    if not os.path.isdir(pool.base_dir):
        return []
    pat = re.compile(r"{}(\d+)$".format(re.escape(pool.dir_prefix)))
    out = []
    for entry in os.listdir(pool.base_dir):
        m = pat.match(entry)
        if m and os.path.isdir(os.path.join(pool.base_dir, entry)):
            out.append(int(m.group(1)))
    return sorted(out)


def default_name(pool, i):
    # the default pool keeps plain <prefix>-<N> names (adoption-friendly);
    # named pools include the pool name to avoid cross-pool collisions
    if pool.name == "default":
        return "{}-{}".format(pool.name_prefix, i)
    return "{}-{}-{}".format(pool.name_prefix, pool.name, i)


def runner_ref(pool, i):
    if pool.instance.single:
        return str(i)
    return "{}/{}".format(pool.name, i)


def resolve_refs(inst, tokens, indices_map, default_all=True):
    """CLI runner addressing -> ordered [(pool, idx)]. Token forms:
    '3' (single-pool file), 'gpu' (whole pool), 'gpu/3'."""
    out = []

    def add_pool(pool):
        idxs = indices_map.get(pool.name)
        if idxs is None:
            raise Err("cannot enumerate pool {!r}: host {} is unreachable".format(
                pool.name, pool.host))
        out.extend((pool, i) for i in idxs)

    if not tokens:
        if not default_all:
            return []
        for pool in inst.pools.values():
            add_pool(pool)
        return out
    for t in tokens:
        t = str(t)
        if "/" in t:
            pname, _, sidx = t.partition("/")
            pool = inst.pools.get(pname)
            if pool is None:
                raise Err("no such pool: {!r} (pools: {})".format(
                    pname, ", ".join(inst.pools)))
            if not sidx.isdigit():
                raise Err("bad runner reference {!r}: expected <pool>/<idx>".format(t))
            out.append((pool, int(sidx)))
        elif t in inst.pools:
            add_pool(inst.pools[t])
        elif t.isdigit():
            if not inst.single:
                raise Err("this config has multiple pools; use <pool>/<idx> or a "
                          "pool name (pools: {})".format(", ".join(inst.pools)))
            out.append((inst.only_pool(), int(t)))
        else:
            raise Err("unknown pool or runner reference: {!r}".format(t))
    return out


# ---------------------------------------------------------------- runner package

def runner_arch():
    m = platform.machine().lower()
    if m in ("x86_64", "amd64"):
        return "x64"
    if m in ("aarch64", "arm64"):
        return "arm64"
    raise Err("unsupported architecture: " + m)


_LATEST_CACHE = []


def resolve_version(pool, gh):
    if pool.version and pool.version != "latest":
        return pool.version.lstrip("v")
    if not _LATEST_CACHE:
        rel = api("GET", "repos/actions/runner/releases/latest", gh.token)
        _LATEST_CACHE.append(rel["tag_name"].lstrip("v"))
    return _LATEST_CACHE[0]


def ensure_tarball(pool, version):
    name = "actions-runner-linux-{}-{}.tar.gz".format(runner_arch(), version)
    path = os.path.join(pool.base_dir, name)
    if os.path.isfile(path):
        return path
    url = "https://github.com/actions/runner/releases/download/v{}/{}".format(version, name)
    info("downloading {}".format(name))
    os.makedirs(pool.base_dir, exist_ok=True)
    tmp = path + ".part"
    milestones = {"done": 0}

    def hook(nblocks, blocksize, total):
        if total <= 0:
            return
        quarter = min(4, nblocks * blocksize * 4 // total)
        if quarter > milestones["done"]:
            milestones["done"] = quarter
            info("downloaded {}% of {} MB".format(quarter * 25, total // 1000000))

    try:
        urllib.request.urlretrieve(url, tmp, reporthook=hook)
    except (urllib.error.URLError, OSError) as e:
        raise Err("download failed: {}".format(e))
    os.replace(tmp, path)
    return path


# ---------------------------------------------------------------- supervisor daemon

class Supervisor:
    """The `runnerctl daemon` runtime: owns every runner process of every
    LOCAL pool as a direct child, restarts each independently with exponential
    backoff, and re-reads the config file on SIGHUP. Holds no GitHub
    credentials and performs no registration work."""

    POLL = 1.0
    QUICK_DEATH = 60.0

    def __init__(self, inst):
        self.inst = inst
        self.children = {}     # (pool_name, idx) -> (pool, subprocess.Popen)
        self.started = {}      # key -> spawn timestamp
        self.failures = {}     # key -> consecutive quick-death count
        self.next_start = {}   # key -> earliest allowed restart time
        self.want_reload = True
        self.stopping = False

    @staticmethod
    def log(msg):
        print("{} {}".format(time.strftime("%Y-%m-%dT%H:%M:%S"), msg), flush=True)

    def desired(self):
        out = OrderedDict()
        for pool in self.inst.pools.values():
            if pool.host:
                continue  # another machine's pool
            for i in local_indices(pool):
                d = runner_dir(pool, i)
                if not os.path.isfile(os.path.join(d, "run.sh")):
                    continue
                if not os.path.isfile(os.path.join(d, ".runner")):
                    continue
                if os.path.exists(disabled_marker(pool, i)):
                    continue
                out[(pool.name, i)] = pool
        return out

    def reload_config(self):
        """SIGHUP: re-read the config file so pool/count edits apply live.
        The instance name is pinned at start (it names the unit and state
        dir); a parse failure keeps the previous config."""
        try:
            fresh = load_config(self.inst.path)
            if self.inst.as_host:
                scope_instance(fresh, self.inst.as_host)
        except Err as e:
            self.log("config reload FAILED, keeping previous config: {}".format(e))
            return
        if fresh.name != self.inst.name:
            self.log("config renamed instance {!r} -> {!r}; ignoring the rename "
                     "(restart the supervisor to apply it)".format(
                         self.inst.name, fresh.name))
            fresh.name = self.inst.name
        self.inst = fresh
        self.log("config reloaded (pools: {})".format(", ".join(self.inst.pools)))

    def spawn(self, pool, i):
        key = (pool.name, i)
        d = runner_dir(pool, i)
        with open(runner_logfile(pool, i), "ab") as logf:
            p = subprocess.Popen([os.path.join(d, "run.sh")], cwd=d,
                                 stdout=logf, stderr=subprocess.STDOUT,
                                 stdin=subprocess.DEVNULL, start_new_session=True)
        self.children[key] = (pool, p)
        self.started[key] = time.time()
        os.makedirs(os.path.dirname(child_pidfile(pool, i)), exist_ok=True)
        with open(child_pidfile(pool, i), "w") as f:
            f.write(str(p.pid))
        self.log("runner {}/{}: started (pid {})".format(pool.name, i, p.pid))

    def stop_child(self, key):
        entry = self.children.pop(key, None)
        if entry is None:
            return
        pool, p = entry
        self.log("runner {}/{}: stopping (pid {})".format(pool.name, key[1], p.pid))
        # own children must be reaped via wait(), not probed with kill-0:
        # an exited child stays a zombie (kill-0 true) until waited on
        for sig, patience in ((signal.SIGINT, 30), (signal.SIGTERM, 10), (signal.SIGKILL, 5)):
            try:
                os.killpg(p.pid, sig)
            except ProcessLookupError:
                break
            try:
                p.wait(timeout=patience)
                break
            except subprocess.TimeoutExpired:
                continue
        p.poll()
        try:
            os.remove(child_pidfile(pool, key[1]))
        except OSError:
            pass

    def reap(self):
        for key, (pool, p) in list(self.children.items()):
            rc = p.poll()
            if rc is None:
                continue
            del self.children[key]
            try:
                os.remove(child_pidfile(pool, key[1]))
            except OSError:
                pass
            quick = time.time() - self.started.get(key, 0) < self.QUICK_DEATH
            self.failures[key] = self.failures.get(key, 0) + 1 if quick else 0
            delay = min(5 * (2 ** self.failures[key]), 300) if self.failures[key] else 2
            self.next_start[key] = time.time() + delay
            self.log("runner {}/{}: exited rc={}; restart in {:.0f}s".format(
                pool.name, key[1], rc, delay))

    def run(self):
        old = read_pid(daemon_pidfile(self.inst))
        if pid_alive(old):
            raise Err("daemon already running (pid {})".format(old))
        for sub in ("pids", "disabled"):
            os.makedirs(os.path.join(state_dir(self.inst), sub), exist_ok=True)
        with open(daemon_pidfile(self.inst), "w") as f:
            f.write(str(os.getpid()))

        def on_hup(signum, frame):
            self.want_reload = True

        def on_stop(signum, frame):
            self.stopping = True

        signal.signal(signal.SIGHUP, on_hup)
        signal.signal(signal.SIGTERM, on_stop)
        signal.signal(signal.SIGINT, on_stop)
        self.log("supervisor started (pid {}, instance {}, pools: {})".format(
            os.getpid(), self.inst.name, ", ".join(self.inst.pools)))
        try:
            while not self.stopping:
                if self.want_reload:
                    self.want_reload = False
                    self.reload_config()
                want = self.desired()
                for key in list(self.children):
                    if key not in want:
                        self.stop_child(key)
                self.reap()
                now = time.time()
                for key, pool in want.items():
                    if key not in self.children and now >= self.next_start.get(key, 0):
                        self.spawn(pool, key[1])
                time.sleep(self.POLL)
        finally:
            self.log("supervisor stopping; shutting down {} runner(s)".format(
                len(self.children)))
            for key in list(self.children):
                self.stop_child(key)
            try:
                os.remove(daemon_pidfile(self.inst))
            except OSError:
                pass
            self.log("supervisor exited")


def systemd_user_available():
    if not shutil.which("systemctl"):
        return False
    p = run(["systemctl", "--user", "is-system-running"])
    state = (p.stdout or "").strip().splitlines()
    state = state[0] if state else ""
    return state in ("running", "degraded", "starting", "initializing", "maintenance")


def unit_name(inst):
    # per-machine name: on shared-home clusters every host sees the same
    # ~/.config/systemd/user, so units must not overwrite each other
    return "runnerctl-{}-{}.service".format(inst.name, machine_id(inst))


def unit_path(inst):
    return os.path.expanduser("~/.config/systemd/user/" + unit_name(inst))


class DaemonController:
    """Hosts and signals the local supervisor: one user-level systemd service
    when a user bus exists, otherwise a detached process (survives logout via
    its own session; not resurrected after reboot)."""

    def __init__(self, inst, announce=False):
        self.inst = inst
        manager = local_manager(inst)
        if manager == "systemd":
            if not systemd_user_available():
                raise Err("manager=systemd but the systemd user bus is unavailable "
                          '(set manager = "nohup" in {})'.format(inst.path))
            self.mode = "systemd"
        elif manager == "nohup":
            self.mode = "detached"
        else:
            self.mode = "systemd" if systemd_user_available() else "detached"
            if announce and self.mode == "detached":
                warn("systemd user bus unavailable; hosting the supervisor as a "
                     "detached process (runners still restart on crash; the "
                     "supervisor itself is not resurrected after reboot)")

    def pid(self):
        return read_pid(daemon_pidfile(self.inst))

    def running(self):
        return pid_alive(self.pid())

    def _script(self):
        return os.path.realpath(os.path.abspath(sys.argv[0]))

    def _scope_args(self):
        if self.inst.as_host:
            return ["--as-host", self.inst.as_host]
        return []

    def _unit_body(self):
        scope = ""
        if self.inst.as_host:
            scope = " --as-host {}".format(self.inst.as_host)
        return (
            "# managed by runnerctl\n"
            "[Unit]\n"
            "Description=runnerctl - GitHub Actions runner pool supervisor ({name})\n"
            "After=network-online.target\n"
            # shared-home clusters: enable symlinks are visible to every
            # machine, so each unit must refuse to start anywhere but home
            "ConditionHost={chost}\n"
            "\n"
            "[Service]\n"
            "ExecStart={script} -c {config}{scope} daemon\n"
            "ExecReload=/bin/kill -HUP $MAINPID\n"
            "Restart=always\n"
            "RestartSec=5\n"
            "KillSignal=SIGTERM\n"
            "TimeoutStopSec=150\n"
            "\n"
            "[Install]\n"
            "WantedBy=default.target\n"
        ).format(name=self.inst.name, script=self._script(),
                 config=os.path.realpath(self.inst.path), scope=scope,
                 chost=socket.gethostname().split(".")[0])

    def _unit_active(self):
        p = run(["systemctl", "--user", "is-active", unit_name(self.inst)])
        return (p.stdout or "").strip() == "active"

    def _ensure_linger(self):
        user = getpass.getuser()
        p = run(["loginctl", "show-user", user, "--property=Linger", "--value"])
        if p.returncode == 0 and (p.stdout or "").strip() == "yes":
            return
        q = run(["loginctl", "enable-linger", user])
        if q.returncode == 0:
            ok("enabled session linger (supervisor survives logout and reboot)")
        else:
            warn("could not enable linger; the supervisor may stop when your last "
                 "session ends (an admin can run: loginctl enable-linger {})".format(user))

    def ensure(self):
        os.makedirs(state_dir(self.inst), exist_ok=True)
        if self.mode == "systemd":
            if self.running() and not self._unit_active():
                info("stopping leftover detached supervisor before systemd takeover")
                self._stop_detached()
            body = self._unit_body()
            upath = unit_path(self.inst)
            current = None
            if os.path.isfile(upath):
                with open(upath) as f:
                    current = f.read()
            if current != body:
                os.makedirs(os.path.dirname(upath), exist_ok=True)
                with open(upath, "w") as f:
                    f.write(body)
                run(["systemctl", "--user", "daemon-reload"])
                info("installed user unit {}".format(upath))
                if self._unit_active():
                    info("unit changed; restarting supervisor")
                    run(["systemctl", "--user", "restart", unit_name(self.inst)], check=True)
            self._ensure_linger()
            if not self._unit_active():
                run(["systemctl", "--user", "enable", "--now", unit_name(self.inst)],
                    check=True)
                self._wait_running()
                info("supervisor started (systemd user service {})".format(
                    unit_name(self.inst)))
        else:
            if self.running():
                return
            with open(daemon_logfile(self.inst), "ab") as logf:
                subprocess.Popen(
                    [self._script(), "-c", os.path.realpath(self.inst.path)]
                    + self._scope_args() + ["daemon"],
                    stdout=logf, stderr=subprocess.STDOUT,
                    stdin=subprocess.DEVNULL, start_new_session=True)
            self._wait_running()
            info("supervisor started (detached, pid {})".format(self.pid()))

    def _wait_running(self, timeout=10):
        deadline = time.time() + timeout
        while time.time() < deadline:
            if self.running():
                return
            time.sleep(0.2)
        raise Err("supervisor did not come up; check `runnerctl logs --daemon`")

    def hup(self):
        pid = self.pid()
        if pid_alive(pid):
            os.kill(pid, signal.SIGHUP)

    def reload_or_start(self):
        self.ensure()
        self.hup()

    def _stop_detached(self):
        pid = self.pid()
        if not pid_alive(pid):
            return
        os.kill(pid, signal.SIGTERM)
        deadline = time.time() + 150
        while time.time() < deadline and pid_alive(pid):
            time.sleep(0.5)
        if pid_alive(pid):
            os.kill(pid, signal.SIGKILL)

    def stop(self):
        if self.mode == "systemd":
            run(["systemctl", "--user", "disable", "--now", unit_name(self.inst)])
        self._stop_detached()


def wait_child_gone(pool, i, timeout=90):
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not pid_alive(read_pid(child_pidfile(pool, i))):
            return True
        time.sleep(0.5)
    return False


def stop_runner_process(pool, dc, i, disable=True):
    """Stop one LOCAL runner: mark it disabled so the supervisor will not
    respawn it, let the supervisor bring it down, fall back to killing."""
    if disable:
        os.makedirs(os.path.dirname(disabled_marker(pool, i)), exist_ok=True)
        with open(disabled_marker(pool, i), "w"):
            pass
    if dc.running():
        dc.hup()
        if wait_child_gone(pool, i):
            return
        warn("supervisor did not stop runner {} in time; killing directly".format(
            runner_ref(pool, i)))
    pid = read_pid(child_pidfile(pool, i))
    if pid_alive(pid):
        kill_process_group(pid)
    try:
        os.remove(child_pidfile(pool, i))
    except OSError:
        pass


def enable_runner(pool, i):
    try:
        os.remove(disabled_marker(pool, i))
    except OSError:
        pass


def runner_state(pool, i, daemon_up):
    if os.path.exists(disabled_marker(pool, i)):
        return "stopped"
    if pid_alive(read_pid(child_pidfile(pool, i))):
        return "running"
    if daemon_up:
        return "pending"
    return "down"


# ---------------------------------------------------------------- pool operations

def provision(pool, i, gh, tarball):
    d = runner_dir(pool, i)
    os.makedirs(d, exist_ok=True)
    if not os.path.isfile(os.path.join(d, "config.sh")):
        info("extracting runner into {}".format(d))
        with tarfile.open(tarball) as tf:
            try:
                tf.extractall(d, filter="tar")
            except TypeError:
                tf.extractall(d)
    name = default_name(pool, i)
    refresh = False
    while True:
        reg = gh.reg_token(refresh=refresh)
        cmd = [os.path.join(d, "config.sh"), "--unattended", "--url", pool.url,
               "--token", reg, "--name", name,
               "--labels", ",".join(pool.labels), "--replace"]
        if pool.group:
            cmd += ["--runnergroup", pool.group]
        info("registering {}".format(name))
        p = run(cmd, cwd=d)
        if p.returncode == 0:
            break
        detail = (p.stdout or "").strip()
        if gh.manual and not gh.env_reg:
            warn("config.sh failed for {}:\n{}".format(name, detail))
            info("the pasted token may be expired or spent; provide a fresh one")
            refresh = True
            continue
        raise Err("config.sh failed for {}:\n{}".format(name, detail))
    ok("registered {}".format(name))


def decommission(pool, i, gh, dc, remote, force):
    d = runner_dir(pool, i)
    name = registered_name(pool, i) or default_name(pool, i)
    entry = remote.get(name)
    if entry and entry.get("busy") and not force:
        warn("{} is running a job; skipped (re-run with --force to kill it)".format(name))
        return False
    stop_runner_process(pool, dc, i)
    if registered_name(pool, i):
        refresh = False
        while True:
            rem = gh.rem_token(refresh=refresh)
            p = run([os.path.join(d, "config.sh"), "remove", "--token", rem], cwd=d)
            if p.returncode == 0:
                break
            if gh.manual and not gh.env_rem:
                warn("config.sh remove failed for {}:\n{}".format(
                    name, (p.stdout or "").strip()))
                info("the pasted token may be expired; provide a fresh one")
                refresh = True
                continue
            if entry:
                gh.delete_runner(entry["id"])
                warn("config.sh remove failed; deleted {} via the API instead".format(name))
            else:
                warn("config.sh remove failed and {} is unknown to GitHub; "
                     "deleting the directory anyway".format(name))
            break
    shutil.rmtree(d, ignore_errors=True)
    enable_runner(pool, i)  # a future runner with this index starts clean
    try:
        os.remove(child_pidfile(pool, i))
    except OSError:
        pass
    ok("removed runner {} ({})".format(runner_ref(pool, i), name))
    return True


# ---------------------------------------------------------------- commands

def plan_line(sym, msg):
    color = {"+": GREEN, "-": RED, "~": YELLOW, "*": CYAN, "!": YELLOW}[sym]
    print("  " + paint(sym, color) + " " + msg)


def plan_done(count):
    if count == 0:
        print("  nothing to do")
    info("dry run — nothing changed")


def cmd_init(dest):
    if os.path.exists(dest):
        raise Err("{} already exists".format(dest))
    with open(dest, "w") as f:
        f.write(CONFIG_TEMPLATE)
    ok("wrote {} — set url (and count), then run `runnerctl up`".format(dest))


# ---------------------------------------------------------------- self-update

def _fetch_self():
    req = urllib.request.Request(RAW_SELF_URL, headers={"User-Agent": "runnerctl"})
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            text = r.read().decode("utf-8")
    except (urllib.error.URLError, OSError) as e:
        raise Err("cannot fetch {}: {}".format(RAW_SELF_URL, e))
    m = re.search(r'^VERSION = "([^"]+)"', text, re.M)
    if not m:
        raise Err("fetched script has no VERSION marker; refusing to trust it")
    return text, m.group(1)


def _vtuple(v):
    return tuple(int(x) for x in re.findall(r"\d+", v)[:3]) or (0,)


def _gh_extension_install():
    # installed via `gh extension install` — the script lives inside gh's
    # managed clone (~/.local/share/gh/extensions/gh-runnerctl/)
    path = os.path.realpath(os.path.abspath(sys.argv[0]))
    return "{0}gh{0}extensions{0}".format(os.sep) in path


def cmd_check_update():
    _, remote = _fetch_self()
    if _vtuple(remote) > _vtuple(VERSION):
        cmd = ("gh extension upgrade runnerctl" if _gh_extension_install()
               else "runnerctl update")
        info("update available: v{} -> v{}  (run `{}`)".format(
            VERSION, remote, cmd))
    elif _vtuple(remote) == _vtuple(VERSION):
        ok("up to date (v{})".format(VERSION))
    else:
        info("local v{} is newer than published v{} (development copy?)".format(
            VERSION, remote))


def cmd_update():
    if _gh_extension_install():
        raise Err("this copy is managed by the gh CLI — "
                  "run `gh extension upgrade runnerctl` instead")
    text, remote = _fetch_self()
    if _vtuple(remote) <= _vtuple(VERSION):
        ok("already up to date (v{})".format(VERSION))
        return
    try:
        compile(text, "runnerctl", "exec")  # syntax sanity before installing
    except SyntaxError as e:
        raise Err("fetched script does not compile; not installing: {}".format(e))
    path = os.path.realpath(os.path.abspath(sys.argv[0]))
    tmp = path + ".new"
    try:
        with open(tmp, "w") as f:
            f.write(text)
        os.chmod(tmp, os.stat(path).st_mode)
        os.replace(tmp, path)
    except OSError as e:
        try:
            os.remove(tmp)
        except OSError:
            pass
        raise Err("cannot install update to {}: {}".format(path, e))
    ok("updated v{} -> v{} ({})".format(VERSION, remote, path))
    info("remote hosts pick the new copy up on the next deploying command; "
         "supervisors keep old code until restarted (`down` + `up`)")


# ---------------------------------------------------------------- up / reload

def _up_local(inst, sessions, dc, force, no_prune):
    total = 0
    for pool in inst.local_pools():
        gh = sessions.for_pool(pool)
        target = pool.count
        tarball = None
        for i in range(1, target + 1):
            if not registered_name(pool, i):
                if tarball is None:
                    tarball = ensure_tarball(pool, resolve_version(pool, gh))
                provision(pool, i, gh, tarball)
            enable_runner(pool, i)  # up means: everything in range runs
        if not no_prune:
            extra = [i for i in local_indices(pool) if i > target]
            if extra:
                if gh.manual:
                    gh.warn_manual("cannot check busy state; surplus runners are "
                                   "removed as-is")
                remote = sessions.remote(pool) if not gh.manual else {}
                for i in sorted(extra, reverse=True):
                    decommission(pool, i, gh, dc, remote, force)
        total += target
    if dc and (total > 0 or dc.running()):
        dc.reload_or_start()


def _up_remote(inst, sessions, rhosts, force):
    for host, pools in inst.remote_hosts().items():
        rh = rhosts[host]
        info("converging {} pool(s) on {}".format(len(pools), host))
        try:
            st = rh.state(inst)  # deploys script + config first
        except Err as e:
            warn(str(e))
            continue
        for pool in pools:
            gh = sessions.for_pool(pool)
            pl = st.get("pools", {}).get(pool.name, {})
            missing = [i for i in range(1, pool.count + 1)
                       if not (pl.get(str(i)) or {}).get("name")]
            surplus = sorted((int(k) for k in pl if int(k) > pool.count), reverse=True)
            prune = []
            for i in surplus:
                name = (pl.get(str(i)) or {}).get("name") or default_name(pool, i)
                if not force and name in sessions.busy(pool, "pruning surplus runners"):
                    warn("{} is running a job; skipped (re-run with --force)".format(name))
                else:
                    prune.append(i)
            tokens = (gh.reg_token(), None) if missing else None
            rc, _out, _err = rh.invoke(
                inst, ["--only", pool.name, "up", "--no-prune"]
                      + (["--force"] if force else []),
                tokens=tokens, stream=True)
            if rc != 0:
                warn("up for pool {!r} on {} failed".format(pool.name, host))
                continue
            if prune:
                rc, _out, _err = rh.invoke(
                    inst, ["--only", pool.name, "rm"]
                          + [str(i) for i in prune] + ["--force"],
                    tokens=(None, gh.rem_token()), stream=True)
                if rc != 0:
                    warn("pruning pool {!r} on {} failed".format(pool.name, host))


def _plan_up(inst, sessions, dc, rhosts, force):
    print(paint("plan", BOLD) + " for instance {} ({}):".format(inst.name, inst.path))
    acts = 0
    for pool in inst.local_pools():
        gh = sessions.for_pool(pool)
        for i in range(1, pool.count + 1):
            if not registered_name(pool, i):
                plan_line("+", "register runner {} as {} ({})".format(
                    runner_ref(pool, i), default_name(pool, i), pool.url))
                acts += 1
            elif os.path.exists(disabled_marker(pool, i)):
                plan_line("~", "clear stopped mark on runner {}".format(
                    runner_ref(pool, i)))
                acts += 1
        for i in sorted((j for j in local_indices(pool) if j > pool.count), reverse=True):
            name = registered_name(pool, i) or default_name(pool, i)
            if gh.manual:
                state = "busy state unknown"
            else:
                try:
                    entry = sessions.remote(pool).get(name)
                except Err:
                    entry = None
                state = "busy" if entry and entry.get("busy") else "idle"
            if state == "busy" and not force:
                plan_line("!", "keep runner {} ({}) — busy; --force would prune "
                               "it".format(runner_ref(pool, i), name))
            else:
                plan_line("-", "deregister and delete runner {} ({}, {})".format(
                    runner_ref(pool, i), name, state))
            acts += 1
    if dc:
        if dc.running():
            plan_line("*", "reload supervisor (SIGHUP pid {})".format(dc.pid()))
        else:
            plan_line("*", "start supervisor ({})".format(
                unit_name(inst) if dc.mode == "systemd" else "detached"))
        acts += 1
    for host, pools in inst.remote_hosts().items():
        rh = rhosts[host]
        try:
            st = rh.state(inst, deploy=False)
        except Err as e:
            plan_line("!", "{}: {} — up would deploy runnerctl and converge "
                           "there".format(host, e))
            acts += 1
            continue
        for pool in pools:
            pl = st.get("pools", {}).get(pool.name, {})
            for i in range(1, pool.count + 1):
                ent = pl.get(str(i)) or {}
                if not ent.get("name"):
                    plan_line("+", "register runner {}/{} on {} as {}".format(
                        pool.name, i, host, default_name(pool, i)))
                    acts += 1
                elif ent.get("state") == "stopped":
                    plan_line("~", "clear stopped mark on {}/{} ({})".format(
                        pool.name, i, host))
                    acts += 1
            for i in sorted((int(k) for k in pl if int(k) > pool.count), reverse=True):
                name = (pl.get(str(i)) or {}).get("name") or default_name(pool, i)
                if name in sessions.busy(pool, "pruning") and not force:
                    plan_line("!", "keep {}/{} on {} ({}) — busy; --force would "
                                   "prune it".format(pool.name, i, host, name))
                else:
                    plan_line("-", "deregister and delete {}/{} on {} ({})".format(
                        pool.name, i, host, name))
                acts += 1
        d = st.get("daemon", {})
        if d.get("running"):
            plan_line("*", "reload supervisor on {} (SIGHUP pid {})".format(
                host, d.get("pid")))
        else:
            plan_line("*", "start supervisor on {}".format(host))
        acts += 1
    plan_done(acts)


def cmd_up(inst, force=False, dry=False, no_prune=False):
    sessions = GitHubSessions()
    rhosts = remote_hosts_for(inst)
    dc = DaemonController(inst, announce=not dry) if inst.local_pools() else None
    if dry:
        _plan_up(inst, sessions, dc, rhosts, force)
        return
    _up_local(inst, sessions, dc, force, no_prune)
    _up_remote(inst, sessions, rhosts, force)
    ok("converged: {}".format(", ".join(
        "{}{}={}".format(p.name, "@" + p.host if p.host else "", p.count)
        for p in inst.pools.values())))
    if not AGENT_MODE:
        cmd_status(inst)


def cmd_reload(inst):
    """Soft apply: (re)start supervisors and make them re-read the config.
    No registration work — `up` additionally registers and prunes."""
    if inst.local_pools():
        dc = DaemonController(inst, announce=True)
        was = dc.running()
        dc.reload_or_start()
        ok("local supervisor {}".format("reloaded" if was else "started"))
    for host, _pools in inst.remote_hosts().items():
        rh = RemoteHost(host)
        try:
            rc, _out, _err = rh.invoke(inst, ["reload"], stream=True)
            if rc != 0:
                warn("reload on {} failed".format(host))
        except Err as e:
            warn(str(e))


# ---------------------------------------------------------------- down / rm / svc

def cmd_down(inst, force=False, dry=False):
    rhosts = remote_hosts_for(inst)
    dc = DaemonController(inst) if inst.local_pools() else None
    sessions = GitHubSessions()
    if dry:
        print(paint("plan", BOLD) + " for instance {} ({}):".format(inst.name, inst.path))
        acts = 0
        if dc and dc.running():
            for pool in inst.local_pools():
                busy = sessions.busy(pool, "stopping the pool")
                for i in local_indices(pool):
                    if runner_state(pool, i, True) != "running":
                        continue
                    name = registered_name(pool, i) or default_name(pool, i)
                    if name in busy and not force:
                        plan_line("!", "runner {} ({}) is busy — down would abort "
                                       "without --force".format(runner_ref(pool, i), name))
                    else:
                        plan_line("-", "stop runner {} ({})".format(
                            runner_ref(pool, i), name))
                    acts += 1
            plan_line("*", "stop supervisor (pid {}, {})".format(dc.pid(), dc.mode))
            acts += 1
        for host in rhosts:
            plan_line("*", "stop supervisor and runners on {}".format(host))
            acts += 1
        plan_done(acts)
        return
    blockers = []
    if not force:
        for pool in inst.pools.values():
            busy = sessions.busy(pool, "stopping the pool")
            blockers += [n for n in busy
                         if n.startswith(pool.name_prefix + "-")]
    if blockers:
        raise Err("busy runner(s): {} — retry with --force to kill their "
                  "jobs, or wait".format(", ".join(sorted(set(blockers)))))
    if dc:
        dc.stop()
        ok("local supervisor stopped")
    for host, _pools in rhosts.items():
        try:
            rc, _out, _err = rhosts[host].invoke(inst, ["down", "--force"], stream=True)
            if rc != 0:
                warn("down on {} failed".format(host))
        except Err as e:
            warn(str(e))
    ok("registrations kept (`runnerctl up` resumes)")


def cmd_rm(inst, tokens, all_flag, force, dry=False):
    rhosts = remote_hosts_for(inst)
    imap = pool_indices_map(inst, rhosts)
    refs = resolve_refs(inst, [] if all_flag else tokens, imap, default_all=all_flag)
    if not refs:
        raise Err("nothing to remove: pass runners (idx, <pool>/<idx>, or a "
                  "pool name) or --all")
    bad = []
    for pool, i in refs:
        known = imap.get(pool.name)
        if not pool.host:
            if i not in local_indices(pool):
                bad.append(runner_ref(pool, i))
        elif known is not None and i not in known:
            bad.append("{}/{} (on {})".format(pool.name, i, pool.host))
    if bad:
        raise Err("no such runner(s): {}".format(", ".join(bad)))
    sessions = GitHubSessions()
    dc = DaemonController(inst) if inst.local_pools() else None
    if dry:
        print(paint("plan", BOLD) + " for instance {} ({}):".format(inst.name, inst.path))
        acts = 0
        for pool, i in sorted(refs, key=lambda r: (r[0].name, r[1])):
            gh = sessions.for_pool(pool)
            at = " on " + pool.host if pool.host else ""
            name = default_name(pool, i)
            if not pool.host:
                name = registered_name(pool, i) or name
            if gh.manual:
                state = "busy state unknown"
            else:
                try:
                    entry = sessions.remote(pool).get(name)
                except Err:
                    entry = None
                state = "busy" if entry and entry.get("busy") else "idle"
            if state == "busy" and not force:
                plan_line("!", "keep runner {}{} ({}) — busy; --force would remove "
                               "it".format(runner_ref(pool, i), at, name))
            else:
                plan_line("-", "deregister and delete runner {}{} ({}, {})".format(
                    runner_ref(pool, i), at, name, state))
            acts += 1
        plan_done(acts)
        return
    removed = []
    remote_batches = OrderedDict()  # (host, pool) -> [idx]
    for pool, i in sorted(refs, key=lambda r: (r[0].name, -r[1])):
        if pool.host:
            remote_batches.setdefault((pool.host, pool), []).append(i)
            continue
        gh = sessions.for_pool(pool)
        if gh.manual:
            gh.warn_manual("cannot check busy state before removal")
        remote = sessions.remote(pool)
        if decommission(pool, i, gh, dc, remote, force):
            removed.append((pool, i))
    if dc and dc.running():
        dc.hup()
    for (host, pool), idxs in remote_batches.items():
        gh = sessions.for_pool(pool)
        keep = []
        if not force:
            busy = sessions.busy(pool, "removal")
            for i in idxs:
                name = default_name(pool, i)
                if name in busy:
                    warn("{} is running a job; skipped (use --force)".format(name))
                else:
                    keep.append(i)
        else:
            keep = idxs
        if not keep:
            continue
        try:
            rc, _out, _err = rhosts[host].invoke(
                inst, ["--only", pool.name, "rm"] + [str(i) for i in keep] + ["--force"],
                tokens=(None, gh.rem_token()), stream=True)
            if rc != 0:
                warn("rm on {} failed".format(host))
            else:
                removed += [(pool, i) for i in keep]
        except Err as e:
            warn(str(e))
    still_wanted = [runner_ref(p, i) for p, i in removed if i <= p.count]
    if still_wanted:
        warn("config still wants these; the next `runnerctl up` will "
             "re-provision {}".format(", ".join(sorted(still_wanted))))


def cmd_svc(inst, action, tokens, force=False):
    rhosts = remote_hosts_for(inst)
    imap = pool_indices_map(inst, rhosts)
    refs = resolve_refs(inst, tokens, imap)
    if not refs:
        raise Err("no registered runners; run `runnerctl up`")
    bad = []
    for pool, i in refs:
        known = imap.get(pool.name)
        if not pool.host and not registered_name(pool, i):
            bad.append(runner_ref(pool, i))
        elif pool.host and known is not None and i not in known:
            bad.append("{}/{} (on {})".format(pool.name, i, pool.host))
    if bad:
        raise Err("no such runner(s): {}".format(", ".join(bad)))
    sessions = GitHubSessions()
    dc = DaemonController(inst, announce=True) if inst.local_pools() else None
    past = {"start": "started", "stop": "stopped", "restart": "restarted"}[action]
    local_touched = False
    remote_batches = OrderedDict()
    for pool, i in refs:
        if pool.host:
            remote_batches.setdefault(pool.host, []).append((pool, i))
            continue
        name = registered_name(pool, i)
        if action in ("stop", "restart") and not force:
            busy = sessions.busy(pool, "stopping runners")
            if name and name in busy:
                warn("{} is running a job; skipped (use --force)".format(name))
                continue
        if action in ("stop", "restart"):
            stop_runner_process(pool, dc, i)
            if action == "stop":
                ok("stopped runner {}".format(runner_ref(pool, i)))
        if action in ("start", "restart"):
            enable_runner(pool, i)
            ok("{} runner {}".format(past if action != "start" else "started",
                                     runner_ref(pool, i)))
        local_touched = True
    if local_touched and dc:
        if action in ("start", "restart"):
            dc.reload_or_start()
        elif dc.running():
            dc.hup()
    for host, items in remote_batches.items():
        todo = []
        for pool, i in items:
            name = default_name(pool, i)
            if action in ("stop", "restart") and not force:
                if name in sessions.busy(pool, "stopping runners"):
                    warn("{} is running a job; skipped (use --force)".format(name))
                    continue
            todo.append("{}/{}".format(pool.name, i))
        if not todo:
            continue
        try:
            rc, _out, _err = rhosts[host].invoke(
                inst, ([action] + todo + ["--force"]) if action != "start"
                else [action] + todo, stream=True)
            if rc != 0:
                warn("{} on {} failed".format(action, host))
        except Err as e:
            warn(str(e))


# ---------------------------------------------------------------- status / logs

def cmd_agent_status(inst):
    """Plumbing for the control machine: local daemon + runner state as JSON."""
    dc = DaemonController(inst)
    daemon_up = dc.running()
    out = {"daemon": {"running": daemon_up, "pid": dc.pid(), "mode": dc.mode},
           "pools": {}}
    for pool in inst.local_pools():
        entry = {}
        for i in local_indices(pool):
            entry[str(i)] = {"name": registered_name(pool, i),
                             "state": runner_state(pool, i, daemon_up)}
        out["pools"][pool.name] = entry
    print(json.dumps(out))


def cmd_status(inst):
    sessions = GitHubSessions()
    rhosts = remote_hosts_for(inst)
    dc = DaemonController(inst)
    local_daemon_up = dc.running()
    show_local = bool(inst.local_pools()) or local_daemon_up
    print()
    print("{} {}   config={}   pools: {}".format(
        paint("instance", BOLD), inst.name, inst.path,
        ", ".join("{}{}={}".format(p.name, "@" + p.host if p.host else "", p.count)
                  for p in inst.pools.values())))
    if show_local:
        dstate = ("running (pid {}, {})".format(dc.pid(), dc.mode)
                  if local_daemon_up else "stopped")
        print("{} {}".format(paint("supervisor", BOLD),
                             paint(dstate, GREEN if local_daemon_up else RED)))
        if not local_daemon_up and any(local_indices(p) for p in inst.local_pools()):
            warn("local supervisor not running — `runnerctl up` starts it")
    host_states = {}
    for host in rhosts:
        try:
            host_states[host] = rhosts[host].state(inst, deploy=False)
            d = host_states[host].get("daemon", {})
            dstate = ("running (pid {}, {})".format(d.get("pid"), d.get("mode"))
                      if d.get("running") else "stopped")
            print("{} {}".format(paint("supervisor@" + host, BOLD),
                                 paint(dstate, GREEN if d.get("running") else RED)))
        except Err as e:
            host_states[host] = None
            print("{} {}".format(paint("supervisor@" + host, BOLD),
                                 paint("unreachable", RED)))
            warn(str(e))
    api_errs = {}
    remotes = {}
    for pool in inst.pools.values():
        gh = sessions.for_pool(pool)
        if gh.manual:
            api_errs[pool.name] = "no GitHub token (set GITHUB_TOKEN or `gh auth login`)"
            remotes[pool.name] = {}
            continue
        try:
            remotes[pool.name] = sessions.remote(pool)
        except Err as e:
            api_errs[pool.name] = str(e)
            remotes[pool.name] = {}
    for msg in sorted(set(api_errs.values())):
        warn("GitHub side unavailable: " + msg)
    rows = [([("POOL", None)] if not inst.single else [])
            + [("IDX", None), ("NAME", None), ("RUNNER", None),
               ("GITHUB", None), ("JOB", None), ("", None)]]
    matched = set()
    for pool in inst.pools.values():
        remote = remotes[pool.name]
        perr = api_errs.get(pool.name)
        pool_label = pool.name + ("@" + host_slug(pool.host) if pool.host else "")
        if pool.host:
            st = host_states.get(pool.host)
            pl = (st or {}).get("pools", {}).get(pool.name, {})
            have = sorted(int(k) for k in pl)
            host_daemon = bool((st or {}).get("daemon", {}).get("running"))
        else:
            have = local_indices(pool)
        indices = sorted(set(have) | set(range(1, pool.count + 1)))
        for i in indices:
            pcell = [(pool_label, None)] if not inst.single else []
            provisioned = i in have
            if pool.host:
                ent = pl.get(str(i)) or {}
                name = ent.get("name") if provisioned else None
                svc = (ent.get("state") or "-") if provisioned else "-"
                if st is None:
                    provisioned, name, svc = True, None, "?"
            else:
                name = registered_name(pool, i) if provisioned else None
                svc = (runner_state(pool, i, local_daemon_up) if provisioned else "-")
            note = ""
            if not provisioned:
                rows.append(pcell + [(str(i), None), (default_name(pool, i), DIM),
                                     ("-", DIM), ("-", DIM), ("-", DIM),
                                     ("not provisioned (runnerctl up)", DIM)])
                continue
            display = name or default_name(pool, i)
            if pool.host and st is None:
                gh_state, job, note = "?", "?", "host unreachable"
                entry = remote.get(display)
                if entry:
                    gh_state = entry.get("status", "?")
                    job = "busy" if entry.get("busy") else "idle"
            elif name:
                matched.add((pool.name, name))
                entry = remote.get(name)
                if entry:
                    gh_state = entry.get("status", "?")
                    job = "busy" if entry.get("busy") else "idle"
                elif perr:
                    gh_state, job = "?", "?"
                else:
                    gh_state, job = "unregistered", "-"
            else:
                gh_state, job = "unconfigured", "-"
                note = "directory exists but was never registered"
            if i > pool.count:
                note = "above configured count (pruned on next up)"
            rows.append(pcell + [
                (str(i), None),
                (display, None),
                (svc, {"running": GREEN, "pending": YELLOW, "down": RED,
                       "?": YELLOW}.get(svc, DIM)),
                (gh_state, {"online": GREEN, "offline": RED, "unregistered": YELLOW,
                            "unconfigured": YELLOW}.get(gh_state, DIM)),
                (job, {"busy": YELLOW, "idle": GREEN}.get(job, DIM)),
                (note, DIM),
            ])
    stale_seen = set()
    for pool in inst.pools.values():
        prefix = (pool.name_prefix + "-" if pool.name == "default"
                  else "{}-{}-".format(pool.name_prefix, pool.name))
        pool_label = pool.name + ("@" + host_slug(pool.host) if pool.host else "")
        for n in sorted(remotes[pool.name]):
            if (not n or not n.startswith(prefix) or (pool.name, n) in matched
                    or n in stale_seen):
                continue
            if any((q.name, n) in matched for q in inst.pools.values()):
                continue
            if pool.host and host_states.get(pool.host) is None:
                continue  # can't distinguish stale from unreachable
            stale_seen.add(n)
            e = remotes[pool.name][n]
            pcell = [(pool_label, DIM)] if not inst.single else []
            rows.append(pcell + [
                ("-", DIM),
                (n, None),
                ("-", DIM),
                (e.get("status", "?"),
                 {"online": GREEN, "offline": RED}.get(e.get("status"), DIM)),
                ("busy" if e.get("busy") else "idle", DIM),
                ("registered on GitHub but no local directory", YELLOW),
            ])
    widths = [max(len(r[c][0]) for r in rows) for c in range(len(rows[0]))]
    print()
    for ri, r in enumerate(rows):
        cells = []
        for c, (text, color) in enumerate(r):
            cell = text.ljust(widths[c])
            if ri == 0:
                cell = paint(cell, BOLD)
            elif color:
                cell = paint(cell, color)
            cells.append(cell)
        print(("  " + "  ".join(cells)).rstrip())
    print()


def cmd_watch(inst, interval):
    if not _tty():
        raise Err("watch needs a terminal (pipe `status` instead)")
    interval = max(2.0, interval)
    while True:
        # poll in flight: render the whole frame into a buffer first, then
        # clear and paint atomically — the screen is never blank mid-fetch
        started = time.time()
        frame = io.StringIO()
        try:
            with contextlib.redirect_stdout(frame), contextlib.redirect_stderr(frame):
                cmd_status(inst)
        except Err as e:
            frame.write(paint("error:", RED) + " " + str(e) + "\n")
        stamp = time.strftime("%H:%M:%S")
        sys.stdout.write("\033[2J\033[H")
        sys.stdout.write(paint("runnerctl watch", BOLD)
                         + "   as of {}   every {:.0f}s — Ctrl-C to quit\n".format(
                             stamp, interval))
        sys.stdout.write(frame.getvalue())
        sys.stdout.flush()
        time.sleep(max(0.5, interval - (time.time() - started)))


def maybe_offer_update(inst):
    """After `status`: check for updates per the check_updates config key
    ("ask" prompts on a TTY, "always" checks silently, "never" skips)."""
    if AGENT_MODE or inst.check_updates == "never":
        return
    if inst.check_updates == "ask":
        if not (_tty() and sys.stdin.isatty()):
            return
        try:
            ans = input('check for updates? [y/N]  (set check_updates = '
                        '"always" or "never" in {} to stop asking) '.format(
                            inst.path)).strip().lower()
        except EOFError:
            return
        if ans not in ("y", "yes"):
            return
    try:
        cmd_check_update()
    except Err as e:
        warn(str(e))


def cmd_logs(inst, token, follow, daemon):
    if daemon:
        dc = DaemonController(inst)
        if dc.mode == "systemd":
            cmd = ["journalctl", "--user", "-u", unit_name(inst), "-n", "100",
                   "--no-pager"]
            if follow:
                cmd.append("-f")
            os.execvp(cmd[0], cmd)
        logf = daemon_logfile(inst)
        if not os.path.isfile(logf):
            raise Err("no supervisor log yet: {}".format(logf))
        cmd = ["tail", "-n", "100"] + (["-f"] if follow else []) + [logf]
        os.execvp(cmd[0], cmd)
    rhosts = remote_hosts_for(inst)
    imap = pool_indices_map(inst, rhosts)
    refs = resolve_refs(inst, [token] if token else [], imap)
    if not refs:
        raise Err("no runners provisioned; run `runnerctl up`")
    if len(refs) != 1:
        raise Err("pick one runner: runnerctl logs {}".format(
            "<idx>" if inst.single else "<pool>/<idx>"))
    pool, idx = refs[0]
    if pool.host:
        rh = rhosts[pool.host]
        rh.deploy(inst)
        script, conf = rh._paths(inst)
        remote_cmd = '"{}" -c "{}" --as-host {} --agent logs {}{}'.format(
            script, conf, shlex.quote(pool.host),
            shlex.quote("{}/{}".format(pool.name, idx)), " -f" if follow else "")
        os.execvp("ssh", ["ssh", "-t", pool.host, "--", remote_cmd])
    logf = runner_logfile(pool, idx)
    if not os.path.isfile(logf):
        raise Err("no log yet for runner {}: {}".format(runner_ref(pool, idx), logf))
    cmd = ["tail", "-n", "100"] + (["-f"] if follow else []) + [logf]
    os.execvp(cmd[0], cmd)


def cmd_config(inst):
    print("config file: {}".format(inst.path))
    print("instance: {}".format(inst.name))
    if inst.local_pools() and local_manager(inst) == "auto":
        print("manager (this machine): auto  (resolves to: {})".format(
            DaemonController(inst).mode))
    for pool in inst.pools.values():
        print("[pool.{}]".format(pool.name) if not inst.single or pool.name != "default"
              else "[pool]")
        for key in ("url", "count", "labels", "base_dir", "version",
                    "name_prefix", "group", "dir_prefix", "host", "manager"):
            val = getattr(pool, key)
            shown = val if isinstance(val, str) else json.dumps(val)
            print("  {} = {}".format(key, shown))


# ---------------------------------------------------------------- entry point

def main(argv=None):
    global AGENT_MODE
    ap = argparse.ArgumentParser(
        prog="runnerctl",
        description="Sudoless, config-driven pool manager for self-hosted "
                    "GitHub Actions runners — local and over ssh. One "
                    "supervisor per machine owns that machine's runners; the "
                    "GitHub token never leaves the control machine.")
    ap.add_argument("-c", "--config", metavar="FILE",
                    help="config file (default: ./runners.toml, "
                         "~/.config/runnerctl/runners.toml)")
    ap.add_argument("--version", action="version", version="runnerctl " + VERSION)
    ap.add_argument("--as-host", metavar="H", help=argparse.SUPPRESS)
    ap.add_argument("--only", metavar="POOL", help=argparse.SUPPRESS)
    ap.add_argument("--tokens-stdin", action="store_true", help=argparse.SUPPRESS)
    ap.add_argument("--agent", action="store_true", help=argparse.SUPPRESS)
    sub = ap.add_subparsers(dest="cmd", metavar="command")
    sub.required = True

    sub.add_parser("init", help="write a starter runners.toml here")
    p = sub.add_parser("up", help="converge every pool to the config "
                                  "(provision, register, supervise, prune)")
    p.add_argument("--force", action="store_true",
                   help="prune surplus runners even if busy")
    p.add_argument("-n", "--dry-run", action="store_true",
                   help="show the plan without changing anything")
    p.add_argument("--no-prune", action="store_true", help=argparse.SUPPRESS)
    sub.add_parser("reload", help="soft apply: supervisors re-read the config "
                                  "(started if stopped); no GitHub work")
    sub.add_parser("status", aliases=["ps"],
                   help="show pool status (supervisors + runners + GitHub)")
    p = sub.add_parser("watch", help="live-refreshing status")
    p.add_argument("-i", "--interval", type=float, default=10, metavar="SEC",
                   help="refresh interval (default 10s, min 2s)")
    p = sub.add_parser("down", help="stop all supervisors and runners; "
                                    "keep registrations")
    p.add_argument("--force", action="store_true", help="stop even busy runners")
    p.add_argument("-n", "--dry-run", action="store_true",
                   help="show the plan without changing anything")
    p = sub.add_parser("rm", help="deregister and delete runners")
    p.add_argument("ref", nargs="*",
                   help="idx | <pool>/<idx> | pool name")
    p.add_argument("--all", action="store_true")
    p.add_argument("--force", action="store_true")
    p.add_argument("-n", "--dry-run", action="store_true",
                   help="show the plan without changing anything")
    for name, hlp in (("start", "start runners (clear their stopped mark)"),
                      ("stop", "stop runners (kept registered, not respawned)"),
                      ("restart", "restart runners")):
        p = sub.add_parser(name, help=hlp)
        p.add_argument("ref", nargs="*", help="idx | <pool>/<idx> | pool name")
        if name in ("stop", "restart"):
            p.add_argument("--force", action="store_true",
                           help="proceed even if the runner is busy")
    p = sub.add_parser("logs", help="show a runner's (or the supervisor's) logs")
    p.add_argument("ref", nargs="?", help="idx | <pool>/<idx>")
    p.add_argument("-f", "--follow", action="store_true")
    p.add_argument("--daemon", action="store_true", help="supervisor log instead")
    sub.add_parser("config", help="print the resolved configuration")
    sub.add_parser("daemon", help="run the supervisor in the foreground "
                                  "(normally started for you by `up`)")
    sub.add_parser("agent-status", help=argparse.SUPPRESS)
    sub.add_parser("check-update", help="check whether a newer runnerctl exists")
    sub.add_parser("update", help="update runnerctl in place (never automatic)")

    args = ap.parse_args(argv)
    AGENT_MODE = bool(args.agent)
    try:
        if args.cmd == "init":
            cmd_init(args.config or "runners.toml")
            return 0
        if args.cmd == "check-update":
            cmd_check_update()
            return 0
        if args.cmd == "update":
            cmd_update()
            return 0
        inst = load_config(find_config(args.config))
        if args.as_host:
            scope_instance(inst, args.as_host)
        if args.only:
            if args.only not in inst.pools:
                raise Err("--only: no such pool {!r}".format(args.only))
            inst.pools = OrderedDict([(args.only, inst.pools[args.only])])
        if args.tokens_stdin:
            reg = sys.stdin.readline().strip()
            rem = sys.stdin.readline().strip()
            if reg:
                os.environ["RUNNERCTL_REG_TOKEN"] = reg
            if rem:
                os.environ["RUNNERCTL_REM_TOKEN"] = rem
        if args.cmd == "up":
            cmd_up(inst, args.force, args.dry_run, args.no_prune)
        elif args.cmd == "reload":
            cmd_reload(inst)
        elif args.cmd in ("status", "ps"):
            cmd_status(inst)
            maybe_offer_update(inst)
        elif args.cmd == "watch":
            cmd_watch(inst, args.interval)
        elif args.cmd == "down":
            cmd_down(inst, args.force, args.dry_run)
        elif args.cmd == "rm":
            cmd_rm(inst, args.ref, args.all, args.force, args.dry_run)
        elif args.cmd in ("start", "stop", "restart"):
            cmd_svc(inst, args.cmd, args.ref, getattr(args, "force", False))
        elif args.cmd == "logs":
            cmd_logs(inst, args.ref, args.follow, args.daemon)
        elif args.cmd == "config":
            cmd_config(inst)
        elif args.cmd == "agent-status":
            cmd_agent_status(inst)
        elif args.cmd == "daemon":
            Supervisor(inst).run()
    except Err as e:
        print(paint("error:", RED) + " " + str(e), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print()
        return 130
    return 0


if __name__ == "__main__":
    sys.exit(main())

class Err(Exception):
    pass


# ---------------------------------------------------------------- output

GREEN, RED, YELLOW, DIM, CYAN, BOLD = "32", "31", "33", "2", "36", "1"


def _tty():
    return sys.stdout.isatty()


def paint(s, code):
    if _tty():
        return "\033[{}m{}\033[0m".format(code, s)
    return s


def info(msg):
    print(paint("::", CYAN) + " " + msg)


def ok(msg):
    print(paint("ok", GREEN) + " " + msg)


def warn(msg):
    print(paint("!!", YELLOW) + " " + msg, file=sys.stderr)


def run(cmd, cwd=None, check=False):
    p = subprocess.run(cmd, cwd=cwd, stdout=subprocess.PIPE,
                       stderr=subprocess.STDOUT, universal_newlines=True)
    if check and p.returncode != 0:
        raise Err("command failed ({}): {}\n{}".format(
            p.returncode, " ".join(cmd), (p.stdout or "").strip()))
    return p


# ---------------------------------------------------------------- config

def _strip_comment(s):
    out, instr, q = [], False, ""
    for ch in s:
        if instr:
            out.append(ch)
            if ch == q:
                instr = False
        elif ch in "\"'":
            instr, q = True, ch
            out.append(ch)
        elif ch == "#":
            break
        else:
            out.append(ch)
    return "".join(out).strip()


def _parse_val(s):
    s = s.strip()
    if s.startswith("["):
        if not s.endswith("]"):
            raise ValueError("arrays must be on one line: " + s)
        inner = s[1:-1].strip()
        if not inner:
            return []
        items, buf, instr, q = [], "", False, ""
        for ch in inner:
            if instr:
                buf += ch
                if ch == q:
                    instr = False
            elif ch in "\"'":
                instr, q = True, ch
                buf += ch
            elif ch == ",":
                items.append(buf.strip())
                buf = ""
            else:
                buf += ch
        if buf.strip():
            items.append(buf.strip())
        return [_parse_val(x) for x in items]
    if (s.startswith('"') and s.endswith('"')) or (s.startswith("'") and s.endswith("'")):
        return s[1:-1]
    if s == "true":
        return True
    if s == "false":
        return False
    try:
        return int(s)
    except ValueError:
        raise ValueError("unquoted value: " + s)


def _parse_toml_min(text):
    """Minimal TOML subset: [tables], strings, ints, bools, one-line string arrays."""
    root = {}
    cur = root
    for lineno, raw in enumerate(text.splitlines(), 1):
        line = _strip_comment(raw.strip())
        if not line:
            continue
        if line.startswith("[") and line.endswith("]"):
            cur = root.setdefault(line[1:-1].strip(), {})
            continue
        if "=" not in line:
            raise ValueError("line {}: expected key = value".format(lineno))
        key, val = line.split("=", 1)
        try:
            cur[key.strip()] = _parse_val(val)
        except ValueError as e:
            raise ValueError("line {}: {}".format(lineno, e))
    return root


try:
    import tomllib

    def parse_toml(text):
        return tomllib.loads(text)
except ImportError:
    parse_toml = _parse_toml_min


class Config:
    def __init__(self, data, path):
        for k, v in data.items():
            setattr(self, k, v)
        self.path = path


def find_config(explicit):
    candidates = []
    if explicit:
        candidates.append(explicit)
    if os.environ.get("RUNNERCTL_CONFIG"):
        candidates.append(os.environ["RUNNERCTL_CONFIG"])
    candidates.append("runners.toml")
    candidates.append(os.path.expanduser("~/.config/runnerctl/runners.toml"))
    for c in candidates:
        if os.path.isfile(c):
            return c
    raise Err("no runners.toml found (searched: {})\nrun `runnerctl init` to create one".format(
        ", ".join(candidates)))


def split_url(url):
    m = re.match(r"https?://github\.com/([^/\s]+?)(?:/([^/\s]+?))?/?$", url.strip())
    if not m:
        raise Err("unsupported url {!r}: expected https://github.com/<org> "
                  "or https://github.com/<owner>/<repo>".format(url))
    return m.group(1), m.group(2)


def api_scope(url):
    owner, repo = split_url(url)
    if repo:
        return "repos/{}/{}".format(owner, repo)
    return "orgs/{}".format(owner)


def load_config(path):
    with open(path) as f:
        text = f.read()
    try:
        doc = parse_toml(text)
    except Exception as e:
        raise Err("cannot parse {}: {}".format(path, e))
    pool = doc.get("pool", {})
    if not isinstance(pool, dict):
        raise Err("{}: [pool] must be a table".format(path))
    unknown = sorted(set(pool) - set(DEFAULTS))
    if unknown:
        warn("{}: ignoring unknown key(s): {}".format(path, ", ".join(unknown)))
    data = dict(DEFAULTS)
    data.update({k: v for k, v in pool.items() if k in DEFAULTS})
    data["name"] = str(data["name"])
    if not re.match(r"[A-Za-z0-9_-]+$", data["name"]):
        raise Err("{}: name must be alphanumeric/dash/underscore".format(path))
    if not data["url"] or "YOUR-ORG" in data["url"]:
        raise Err("set `url` in {} to your org or repo".format(path))
    api_scope(data["url"])  # validate shape early
    if not isinstance(data["count"], int) or data["count"] < 0:
        raise Err("{}: count must be a non-negative integer".format(path))
    if isinstance(data["labels"], str):
        data["labels"] = [data["labels"]]
    if not data["labels"] or not all(isinstance(x, str) for x in data["labels"]):
        raise Err("{}: labels must be a non-empty list of strings".format(path))
    if data["manager"] not in ("auto", "systemd", "nohup"):
        raise Err('{}: manager must be "auto", "systemd" or "nohup"'.format(path))
    data["base_dir"] = os.path.abspath(os.path.expanduser(str(data["base_dir"])))
    data["version"] = str(data["version"])
    if not data["name_prefix"]:
        data["name_prefix"] = socket.gethostname().split(".")[0]
    return Config(data, path)


def rewrite_count(cfg, n):
    """Persist a new count into the config file (scale is config-driven)."""
    with open(cfg.path) as f:
        text = f.read()
    new, hits = re.subn(r"(?m)^(\s*count\s*=\s*)\d+", r"\g<1>{}".format(n), text, count=1)
    if hits == 0:
        new, hits = re.subn(r"(?m)^\[pool\][ \t]*$", "[pool]\ncount = {}".format(n),
                            text, count=1)
    if hits == 0:
        raise Err("cannot find a place for `count` in {}".format(cfg.path))
    with open(cfg.path, "w") as f:
        f.write(new)
    info("set count = {} in {}".format(n, cfg.path))


# ---------------------------------------------------------------- GitHub

def get_token():
    for var in ("GITHUB_TOKEN", "GH_TOKEN"):
        if os.environ.get(var):
            return os.environ[var].strip()
    if shutil.which("gh"):
        p = run(["gh", "auth", "token"])
        if p.returncode == 0 and (p.stdout or "").strip():
            return p.stdout.strip().splitlines()[-1]
    return None


def api(method, path, token, body=None):
    url = path if path.startswith("http") else "{}/{}".format(API_ROOT, path)
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Accept", "application/vnd.github+json")
    req.add_header("X-GitHub-Api-Version", "2022-11-28")
    req.add_header("User-Agent", "runnerctl")
    if token:
        req.add_header("Authorization", "Bearer " + token)
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            raw = resp.read()
    except urllib.error.HTTPError as e:
        detail = e.read().decode("utf-8", "replace")
        try:
            detail = json.loads(detail).get("message", detail)
        except ValueError:
            pass
        raise Err("GitHub API {} {} -> HTTP {}: {}".format(method, path, e.code, detail))
    except urllib.error.URLError as e:
        raise Err("GitHub API unreachable: {}".format(e.reason))
    if not raw:
        return {}
    return json.loads(raw.decode("utf-8"))


class GitHub:
    """Token acquisition ladder: GITHUB_TOKEN/GH_TOKEN -> gh CLI -> interactive prompt.

    With an API token, registration/removal tokens are minted automatically and
    remote runner status is available. Without one, the user is prompted to paste
    tokens from the GitHub settings pages (valid ~1h, reused within the run) and
    remote status/busy checks are unavailable.
    """

    def __init__(self, cfg):
        self.cfg = cfg
        self.scope = api_scope(cfg.url)
        self.token = get_token()
        self._reg = None
        self._rem = None
        self._reg_cache = (None, 0.0)
        self._rem_cache = (None, 0.0)
        self._warned = False

    @property
    def manual(self):
        return self.token is None

    def warn_manual(self, what):
        if not self._warned:
            warn("no GitHub token (GITHUB_TOKEN / `gh auth login`): {}".format(what))
            self._warned = True

    def _settings_page(self):
        owner, repo = split_url(self.cfg.url)
        if repo:
            return "https://github.com/{}/{}/settings/actions/runners".format(owner, repo)
        return "https://github.com/organizations/{}/settings/actions/runners".format(owner)

    def _prompt(self, kind, page):
        if not sys.stdin.isatty():
            raise Err("no GitHub token and stdin is not a terminal; "
                      "set GITHUB_TOKEN or run interactively")
        self.warn_manual("switching to manually pasted tokens")
        print()
        info("open:  {}".format(page))
        info("copy the value shown after --token in the {} command".format(kind))
        try:
            val = input("paste {} token (empty aborts): ".format(kind)).strip()
        except EOFError:
            val = ""
        print()
        if not val:
            raise Err("aborted: no {} token provided".format(kind))
        return val

    def _minted(self, cache, kind, refresh):
        """API-minted tokens last ~1h: mint once, reuse across a whole
        up/rm pass instead of one API call per runner."""
        value, good_until = cache
        if refresh or value is None or time.time() > good_until:
            value = api("POST", "{}/actions/runners/{}-token".format(self.scope, kind),
                        self.token)["token"]
            good_until = time.time() + 45 * 60
        return value, (value, good_until)

    def reg_token(self, refresh=False):
        if self.manual:
            if self._reg is None or refresh:
                self._reg = self._prompt("registration", self._settings_page() + "/new")
            return self._reg
        token, self._reg_cache = self._minted(self._reg_cache, "registration", refresh)
        return token

    def rem_token(self, refresh=False):
        if self.manual:
            if self._rem is None or refresh:
                self._rem = self._prompt("removal", self._settings_page())
            return self._rem
        token, self._rem_cache = self._minted(self._rem_cache, "remove", refresh)
        return token

    def runners(self):
        """name -> API entry for every runner registered at this scope."""
        if self.manual:
            return {}
        out, page = {}, 1
        while True:
            r = api("GET", "{}/actions/runners?per_page=100&page={}".format(self.scope, page),
                    self.token)
            batch = r.get("runners", [])
            for x in batch:
                out[x.get("name")] = x
            if len(batch) < 100:
                break
            page += 1
        return out

    def delete_runner(self, runner_id):
        api("DELETE", "{}/actions/runners/{}".format(self.scope, runner_id), self.token)


# ---------------------------------------------------------------- local pool state

def runner_dir(cfg, i):
    return os.path.join(cfg.base_dir, "{}{}".format(cfg.dir_prefix, i))


def state_dir(cfg):
    # namespaced by pool name so pools sharing a base_dir (with distinct
    # dir_prefix) get independent supervisors and markers
    return os.path.join(cfg.base_dir, ".runnerctl", cfg.name)


def daemon_pidfile(cfg):
    return os.path.join(state_dir(cfg), "daemon.pid")


def daemon_logfile(cfg):
    return os.path.join(state_dir(cfg), "daemon.log")


def child_pidfile(cfg, i):
    return os.path.join(state_dir(cfg), "pids", "{}.pid".format(i))


def disabled_marker(cfg, i):
    return os.path.join(state_dir(cfg), "disabled", str(i))


def runner_logfile(cfg, i):
    return os.path.join(runner_dir(cfg, i), "runner.log")


def read_pid(path):
    try:
        with open(path) as f:
            return int(f.read().strip())
    except (OSError, ValueError):
        return None


def pid_alive(pid):
    if pid is None:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def kill_process_group(pid):
    """Graceful escalation against a runner's process group (pgid == pid,
    children are spawned with start_new_session)."""
    for sig, patience in ((signal.SIGINT, 30), (signal.SIGTERM, 10), (signal.SIGKILL, 5)):
        try:
            os.killpg(pid, sig)
        except ProcessLookupError:
            return
        deadline = time.time() + patience
        while time.time() < deadline and pid_alive(pid):
            time.sleep(0.5)
        if not pid_alive(pid):
            return


def registered_name(cfg, i):
    path = os.path.join(runner_dir(cfg, i), ".runner")
    if not os.path.isfile(path):
        return None
    try:
        with open(path, encoding="utf-8-sig") as f:
            return json.load(f).get("agentName")
    except (ValueError, OSError):
        return None


def local_indices(cfg):
    if not os.path.isdir(cfg.base_dir):
        return []
    pat = re.compile(r"{}(\d+)$".format(re.escape(cfg.dir_prefix)))
    out = []
    for entry in os.listdir(cfg.base_dir):
        m = pat.match(entry)
        if m and os.path.isdir(os.path.join(cfg.base_dir, entry)):
            out.append(int(m.group(1)))
    return sorted(out)


def default_name(cfg, i):
    # the default pool keeps plain <host>-<N> names (adoption-friendly);
    # named pools include the pool name to avoid cross-pool collisions
    if cfg.name == "default":
        return "{}-{}".format(cfg.name_prefix, i)
    return "{}-{}-{}".format(cfg.name_prefix, cfg.name, i)


# ---------------------------------------------------------------- runner package

def runner_arch():
    m = platform.machine().lower()
    if m in ("x86_64", "amd64"):
        return "x64"
    if m in ("aarch64", "arm64"):
        return "arm64"
    raise Err("unsupported architecture: " + m)


def resolve_version(cfg, gh):
    if cfg.version and cfg.version != "latest":
        return cfg.version.lstrip("v")
    rel = api("GET", "repos/actions/runner/releases/latest", gh.token)
    return rel["tag_name"].lstrip("v")


def ensure_tarball(cfg, version):
    name = "actions-runner-linux-{}-{}.tar.gz".format(runner_arch(), version)
    path = os.path.join(cfg.base_dir, name)
    if os.path.isfile(path):
        return path
    url = "https://github.com/actions/runner/releases/download/v{}/{}".format(version, name)
    info("downloading {}".format(name))
    os.makedirs(cfg.base_dir, exist_ok=True)
    tmp = path + ".part"
    try:
        urllib.request.urlretrieve(url, tmp)
    except (urllib.error.URLError, OSError) as e:
        raise Err("download failed: {}".format(e))
    os.replace(tmp, path)
    return path


# ---------------------------------------------------------------- supervisor daemon

class Supervisor:
    """The `runnerctl daemon` runtime: owns every runner process as a direct
    child, restarts each independently with exponential backoff, and re-reads
    desired state (registered runner dirs minus disabled markers) on SIGHUP.
    Holds no GitHub credentials and performs no registration work."""

    POLL = 1.0
    QUICK_DEATH = 60.0

    def __init__(self, cfg):
        self.cfg = cfg
        self.children = {}     # idx -> subprocess.Popen
        self.started = {}      # idx -> spawn timestamp
        self.failures = {}     # idx -> consecutive quick-death count
        self.next_start = {}   # idx -> earliest allowed restart time
        self.want_reload = True
        self.stopping = False

    @staticmethod
    def log(msg):
        print("{} {}".format(time.strftime("%Y-%m-%dT%H:%M:%S"), msg), flush=True)

    def desired(self):
        out = []
        for i in local_indices(self.cfg):
            d = runner_dir(self.cfg, i)
            if not os.path.isfile(os.path.join(d, "run.sh")):
                continue
            if not os.path.isfile(os.path.join(d, ".runner")):
                continue
            if os.path.exists(disabled_marker(self.cfg, i)):
                continue
            out.append(i)
        return out

    def spawn(self, i):
        d = runner_dir(self.cfg, i)
        with open(runner_logfile(self.cfg, i), "ab") as logf:
            p = subprocess.Popen([os.path.join(d, "run.sh")], cwd=d,
                                 stdout=logf, stderr=subprocess.STDOUT,
                                 stdin=subprocess.DEVNULL, start_new_session=True)
        self.children[i] = p
        self.started[i] = time.time()
        os.makedirs(os.path.dirname(child_pidfile(self.cfg, i)), exist_ok=True)
        with open(child_pidfile(self.cfg, i), "w") as f:
            f.write(str(p.pid))
        self.log("runner {}: started (pid {})".format(i, p.pid))

    def stop_child(self, i):
        p = self.children.pop(i, None)
        if p is None:
            return
        self.log("runner {}: stopping (pid {})".format(i, p.pid))
        # own children must be reaped via wait(), not probed with kill-0:
        # an exited child stays a zombie (kill-0 true) until waited on
        for sig, patience in ((signal.SIGINT, 30), (signal.SIGTERM, 10), (signal.SIGKILL, 5)):
            try:
                os.killpg(p.pid, sig)
            except ProcessLookupError:
                break
            try:
                p.wait(timeout=patience)
                break
            except subprocess.TimeoutExpired:
                continue
        p.poll()
        try:
            os.remove(child_pidfile(self.cfg, i))
        except OSError:
            pass

    def reap(self):
        for i, p in list(self.children.items()):
            rc = p.poll()
            if rc is None:
                continue
            del self.children[i]
            try:
                os.remove(child_pidfile(self.cfg, i))
            except OSError:
                pass
            quick = time.time() - self.started.get(i, 0) < self.QUICK_DEATH
            self.failures[i] = self.failures.get(i, 0) + 1 if quick else 0
            delay = min(5 * (2 ** self.failures[i]), 300) if self.failures[i] else 2
            self.next_start[i] = time.time() + delay
            self.log("runner {}: exited rc={}; restart in {:.0f}s".format(i, rc, delay))

    def run(self):
        old = read_pid(daemon_pidfile(self.cfg))
        if pid_alive(old):
            raise Err("daemon already running (pid {})".format(old))
        for sub in ("pids", "disabled"):
            os.makedirs(os.path.join(state_dir(self.cfg), sub), exist_ok=True)
        with open(daemon_pidfile(self.cfg), "w") as f:
            f.write(str(os.getpid()))

        def on_hup(signum, frame):
            self.want_reload = True

        def on_stop(signum, frame):
            self.stopping = True

        signal.signal(signal.SIGHUP, on_hup)
        signal.signal(signal.SIGTERM, on_stop)
        signal.signal(signal.SIGINT, on_stop)
        self.log("supervisor started (pid {}, base {})".format(os.getpid(), self.cfg.base_dir))
        try:
            while not self.stopping:
                if self.want_reload:
                    self.want_reload = False
                    self.log("rescanning pool state")
                want = self.desired()
                for i in list(self.children):
                    if i not in want:
                        self.stop_child(i)
                self.reap()
                now = time.time()
                for i in want:
                    if i not in self.children and now >= self.next_start.get(i, 0):
                        self.spawn(i)
                time.sleep(self.POLL)
        finally:
            self.log("supervisor stopping; shutting down {} runner(s)".format(len(self.children)))
            for i in list(self.children):
                self.stop_child(i)
            try:
                os.remove(daemon_pidfile(self.cfg))
            except OSError:
                pass
            self.log("supervisor exited")


def systemd_user_available():
    if not shutil.which("systemctl"):
        return False
    p = run(["systemctl", "--user", "is-system-running"])
    state = (p.stdout or "").strip().splitlines()
    state = state[0] if state else ""
    return state in ("running", "degraded", "starting", "initializing", "maintenance")


class DaemonController:
    """Hosts and signals the supervisor: one user-level systemd service when a
    user bus exists, otherwise a detached process (survives logout via its own
    session; not resurrected after reboot)."""

    def __init__(self, cfg, announce=False):
        self.cfg = cfg
        if cfg.manager == "systemd":
            if not systemd_user_available():
                raise Err("manager=systemd but the systemd user bus is unavailable "
                          '(set manager = "nohup" in {})'.format(cfg.path))
            self.mode = "systemd"
        elif cfg.manager == "nohup":
            self.mode = "detached"
        else:
            self.mode = "systemd" if systemd_user_available() else "detached"
            if announce and self.mode == "detached":
                warn("systemd user bus unavailable; hosting the supervisor as a "
                     "detached process (runners still restart on crash; the "
                     "supervisor itself is not resurrected after reboot)")

    def pid(self):
        return read_pid(daemon_pidfile(self.cfg))

    def running(self):
        return pid_alive(self.pid())

    def _script(self):
        return os.path.realpath(os.path.abspath(sys.argv[0]))

    def _unit_body(self):
        return (
            "# managed by runnerctl\n"
            "[Unit]\n"
            "Description=runnerctl - GitHub Actions runner pool supervisor\n"
            "After=network-online.target\n"
            "\n"
            "[Service]\n"
            "ExecStart={script} -c {config} daemon\n"
            "ExecReload=/bin/kill -HUP $MAINPID\n"
            "Restart=always\n"
            "RestartSec=5\n"
            "KillSignal=SIGTERM\n"
            "TimeoutStopSec=150\n"
            "\n"
            "[Install]\n"
            "WantedBy=default.target\n"
        ).format(script=self._script(), config=os.path.realpath(self.cfg.path))

    def _unit_active(self):
        p = run(["systemctl", "--user", "is-active", unit_name(self.cfg)])
        return (p.stdout or "").strip() == "active"

    def _ensure_linger(self):
        user = getpass.getuser()
        p = run(["loginctl", "show-user", user, "--property=Linger", "--value"])
        if p.returncode == 0 and (p.stdout or "").strip() == "yes":
            return
        q = run(["loginctl", "enable-linger", user])
        if q.returncode == 0:
            ok("enabled session linger (supervisor survives logout and reboot)")
        else:
            warn("could not enable linger; the supervisor may stop when your last "
                 "session ends (an admin can run: loginctl enable-linger {})".format(user))

    def ensure(self):
        os.makedirs(state_dir(self.cfg), exist_ok=True)
        if self.mode == "systemd":
            if self.running() and not self._unit_active():
                info("stopping leftover detached supervisor before systemd takeover")
                self._stop_detached()
            body = self._unit_body()
            upath = unit_path(self.cfg)
            current = None
            if os.path.isfile(upath):
                with open(upath) as f:
                    current = f.read()
            if current != body:
                os.makedirs(os.path.dirname(upath), exist_ok=True)
                with open(upath, "w") as f:
                    f.write(body)
                run(["systemctl", "--user", "daemon-reload"])
                info("installed user unit {}".format(upath))
                if self._unit_active():
                    info("unit changed; restarting supervisor")
                    run(["systemctl", "--user", "restart", unit_name(self.cfg)], check=True)
            self._ensure_linger()
            if not self._unit_active():
                run(["systemctl", "--user", "enable", "--now", unit_name(self.cfg)], check=True)
                self._wait_running()
                info("supervisor started (systemd user service {})".format(unit_name(self.cfg)))
        else:
            if self.running():
                return
            with open(daemon_logfile(self.cfg), "ab") as logf:
                subprocess.Popen(
                    [self._script(), "-c", os.path.realpath(self.cfg.path), "daemon"],
                    stdout=logf, stderr=subprocess.STDOUT,
                    stdin=subprocess.DEVNULL, start_new_session=True)
            self._wait_running()
            info("supervisor started (detached, pid {})".format(self.pid()))

    def _wait_running(self, timeout=10):
        deadline = time.time() + timeout
        while time.time() < deadline:
            if self.running():
                return
            time.sleep(0.2)
        raise Err("supervisor did not come up; check `runnerctl logs --daemon`")

    def hup(self):
        pid = self.pid()
        if pid_alive(pid):
            os.kill(pid, signal.SIGHUP)

    def reload_or_start(self):
        self.ensure()
        self.hup()

    def _stop_detached(self):
        pid = self.pid()
        if not pid_alive(pid):
            return
        os.kill(pid, signal.SIGTERM)
        deadline = time.time() + 150
        while time.time() < deadline and pid_alive(pid):
            time.sleep(0.5)
        if pid_alive(pid):
            os.kill(pid, signal.SIGKILL)

    def stop(self):
        if self.mode == "systemd":
            run(["systemctl", "--user", "disable", "--now", unit_name(self.cfg)])
        self._stop_detached()


def wait_child_gone(cfg, i, timeout=90):
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not pid_alive(read_pid(child_pidfile(cfg, i))):
            return True
        time.sleep(0.5)
    return False


def stop_runner_process(cfg, dc, i, disable=True):
    """Stop one runner: mark it disabled so the supervisor will not respawn it,
    let the supervisor bring it down, fall back to killing directly."""
    if disable:
        os.makedirs(os.path.dirname(disabled_marker(cfg, i)), exist_ok=True)
        with open(disabled_marker(cfg, i), "w"):
            pass
    if dc.running():
        dc.hup()
        if wait_child_gone(cfg, i):
            return
        warn("supervisor did not stop runner {} in time; killing directly".format(i))
    pid = read_pid(child_pidfile(cfg, i))
    if pid_alive(pid):
        kill_process_group(pid)
    try:
        os.remove(child_pidfile(cfg, i))
    except OSError:
        pass


def enable_runner(cfg, i):
    try:
        os.remove(disabled_marker(cfg, i))
    except OSError:
        pass


def runner_state(cfg, i, daemon_up):
    if os.path.exists(disabled_marker(cfg, i)):
        return "stopped"
    if pid_alive(read_pid(child_pidfile(cfg, i))):
        return "running"
    if daemon_up:
        return "pending"
    return "down"


# ---------------------------------------------------------------- pool operations

def provision(cfg, i, gh, tarball):
    d = runner_dir(cfg, i)
    os.makedirs(d, exist_ok=True)
    if not os.path.isfile(os.path.join(d, "config.sh")):
        info("extracting runner into {}".format(d))
        with tarfile.open(tarball) as tf:
            try:
                tf.extractall(d, filter="tar")
            except TypeError:
                tf.extractall(d)
    name = default_name(cfg, i)
    refresh = False
    while True:
        reg = gh.reg_token(refresh=refresh)
        cmd = [os.path.join(d, "config.sh"), "--unattended", "--url", cfg.url,
               "--token", reg, "--name", name,
               "--labels", ",".join(cfg.labels), "--replace"]
        if cfg.group:
            cmd += ["--runnergroup", cfg.group]
        info("registering {}".format(name))
        p = run(cmd, cwd=d)
        if p.returncode == 0:
            break
        detail = (p.stdout or "").strip()
        if gh.manual:
            warn("config.sh failed for {}:\n{}".format(name, detail))
            info("the pasted token may be expired or spent; provide a fresh one")
            refresh = True
            continue
        raise Err("config.sh failed for {}:\n{}".format(name, detail))
    ok("registered {}".format(name))


def decommission(cfg, i, gh, dc, remote, force):
    d = runner_dir(cfg, i)
    name = registered_name(cfg, i) or default_name(cfg, i)
    entry = remote.get(name)
    if entry and entry.get("busy") and not force:
        warn("{} is running a job; skipped (re-run with --force to kill it)".format(name))
        return False
    stop_runner_process(cfg, dc, i)
    if registered_name(cfg, i):
        refresh = False
        while True:
            rem = gh.rem_token(refresh=refresh)
            p = run([os.path.join(d, "config.sh"), "remove", "--token", rem], cwd=d)
            if p.returncode == 0:
                break
            if gh.manual:
                warn("config.sh remove failed for {}:\n{}".format(
                    name, (p.stdout or "").strip()))
                info("the pasted token may be expired; provide a fresh one")
                refresh = True
                continue
            if entry:
                gh.delete_runner(entry["id"])
                warn("config.sh remove failed; deleted {} via the API instead".format(name))
            else:
                warn("config.sh remove failed and {} is unknown to GitHub; "
                     "deleting the directory anyway".format(name))
            break
    shutil.rmtree(d, ignore_errors=True)
    enable_runner(cfg, i)  # a future runner with this index starts clean
    try:
        os.remove(child_pidfile(cfg, i))
    except OSError:
        pass
    ok("removed runner {} ({})".format(i, name))
    return True


def fetch_busy(cfg, purpose):
    """Best-effort busy map for guards; empty when no token is available."""
    gh = GitHub(cfg)
    if gh.manual:
        gh.warn_manual("cannot check busy state before {}".format(purpose))
        return {}
    try:
        return {n: e for n, e in gh.runners().items() if e.get("busy")}
    except Err as e:
        warn(str(e))
        return {}


# ---------------------------------------------------------------- commands

def cmd_init(dest):
    if os.path.exists(dest):
        raise Err("{} already exists".format(dest))
    with open(dest, "w") as f:
        f.write(CONFIG_TEMPLATE)
    ok("wrote {} — set url (and count), then run `runnerctl up`".format(dest))


def cmd_up(cfg, count=None, force=False):
    gh = GitHub(cfg)
    dc = DaemonController(cfg, announce=True)
    target = cfg.count if count is None else count
    if target < 0:
        raise Err("count must be >= 0")
    if count is not None and count != cfg.count:
        info("converging to {} for this run (config says {}; "
             "`runnerctl scale {}` makes it permanent)".format(count, cfg.count, count))
    tarball = None
    for i in range(1, target + 1):
        if not registered_name(cfg, i):
            if tarball is None:
                tarball = ensure_tarball(cfg, resolve_version(cfg, gh))
            provision(cfg, i, gh, tarball)
        enable_runner(cfg, i)  # up means: everything in range runs
    extra = [i for i in local_indices(cfg) if i > target]
    if extra:
        if gh.manual:
            gh.warn_manual("cannot check busy state; surplus runners are removed as-is")
        remote = gh.runners()
        for i in sorted(extra, reverse=True):
            decommission(cfg, i, gh, dc, remote, force)
    if target > 0 or dc.running():
        dc.reload_or_start()
    ok("pool converged to {} runner(s)".format(target))
    cmd_status(cfg)


def cmd_scale(cfg, n, force=False):
    if n < 0:
        raise Err("count must be >= 0")
    if n != cfg.count:
        rewrite_count(cfg, n)
        cfg = load_config(cfg.path)
    cmd_up(cfg, None, force)


def cmd_down(cfg, force=False):
    dc = DaemonController(cfg)
    if not dc.running() and dc.mode == "detached":
        ok("supervisor already stopped")
        return
    if not force:
        busy = fetch_busy(cfg, "stopping the pool")
        blockers = [n for i in local_indices(cfg)
                    for n in [registered_name(cfg, i)] if n and n in busy]
        if blockers:
            raise Err("busy runner(s): {} — retry with --force to kill their "
                      "jobs, or wait".format(", ".join(blockers)))
    dc.stop()
    ok("supervisor stopped; registrations kept (`runnerctl up` resumes)")


def cmd_rm(cfg, indices, all_flag, force):
    have = local_indices(cfg)
    targets = have if all_flag else sorted(set(indices))
    if not targets:
        raise Err("nothing to remove: pass indices or --all")
    bad = [i for i in targets if i not in have]
    if bad:
        raise Err("no such runner(s): {}".format(", ".join(map(str, bad))))
    gh = GitHub(cfg)
    dc = DaemonController(cfg)
    if gh.manual:
        gh.warn_manual("cannot check busy state before removal")
    remote = gh.runners()
    removed = []
    for i in sorted(targets, reverse=True):
        if decommission(cfg, i, gh, dc, remote, force):
            removed.append(i)
    if dc.running():
        dc.hup()
    still_wanted = [i for i in removed if i <= cfg.count]
    if still_wanted:
        warn("config still wants count={}; the next `runnerctl up` will "
             "re-provision {}".format(cfg.count, ", ".join(map(str, sorted(still_wanted)))))


def cmd_svc(cfg, action, indices, force=False):
    have = [i for i in local_indices(cfg) if registered_name(cfg, i)]
    if not have:
        raise Err("no registered runners; run `runnerctl up`")
    targets = sorted(set(indices)) if indices else have
    bad = [i for i in targets if i not in have]
    if bad:
        raise Err("no such runner(s): {}".format(", ".join(map(str, bad))))
    dc = DaemonController(cfg, announce=True)
    busy = {}
    if action in ("stop", "restart") and not force:
        busy = fetch_busy(cfg, action + "ping" if action == "stop" else "restarting")
    for i in targets:
        name = registered_name(cfg, i)
        if name and name in busy:
            warn("{} is running a job; skipped (use --force)".format(name))
            continue
        if action in ("stop", "restart"):
            stop_runner_process(cfg, dc, i)
            if action == "stop":
                ok("stopped runner {}".format(i))
        if action in ("start", "restart"):
            enable_runner(cfg, i)
            ok("{} runner {}".format("restarted" if action == "restart" else "started", i))
    if action in ("start", "restart"):
        dc.reload_or_start()
    elif dc.running():
        dc.hup()


def cmd_status(cfg):
    dc = DaemonController(cfg)
    daemon_up = dc.running()
    gh = GitHub(cfg)
    remote, api_err = {}, None
    if gh.manual:
        api_err = "no GitHub token (set GITHUB_TOKEN or `gh auth login`)"
    else:
        try:
            remote = gh.runners()
        except Err as e:
            api_err = str(e)
    have = local_indices(cfg)
    indices = sorted(set(have) | set(range(1, cfg.count + 1)))
    dstate = ("running (pid {}, {})".format(dc.pid(), dc.mode) if daemon_up
              else "stopped")
    print()
    print("{} {} ({})   base={}   config: count={}".format(
        paint("pool", BOLD), cfg.name, cfg.url, cfg.base_dir, cfg.count))
    print("{} {}".format(paint("supervisor", BOLD),
                         paint(dstate, GREEN if daemon_up else RED)))
    if not daemon_up and have:
        warn("supervisor not running — `runnerctl up` starts it")
    if api_err:
        warn("GitHub side unavailable: " + api_err)
    rows = [[("IDX", None), ("NAME", None), ("RUNNER", None),
             ("GITHUB", None), ("JOB", None), ("", None)]]
    matched = set()
    for i in indices:
        provisioned = i in have
        name = registered_name(cfg, i) if provisioned else None
        note = ""
        if not provisioned:
            rows.append([(str(i), None), (default_name(cfg, i), DIM), ("-", DIM),
                         ("-", DIM), ("-", DIM), ("not provisioned (runnerctl up)", DIM)])
            continue
        display = name or default_name(cfg, i)
        svc = runner_state(cfg, i, daemon_up)
        if name:
            matched.add(name)
            entry = remote.get(name)
            if entry:
                gh_state = entry.get("status", "?")
                job = "busy" if entry.get("busy") else "idle"
            elif api_err:
                gh_state, job = "?", "?"
            else:
                gh_state, job = "unregistered", "-"
        else:
            gh_state, job = "unconfigured", "-"
            note = "directory exists but was never registered"
        if i > cfg.count:
            note = "above configured count (pruned on next up)"
        rows.append([
            (str(i), None),
            (display, None),
            (svc, {"running": GREEN, "pending": YELLOW, "down": RED}.get(svc, DIM)),
            (gh_state, {"online": GREEN, "offline": RED,
                        "unregistered": YELLOW, "unconfigured": YELLOW}.get(gh_state, DIM)),
            (job, {"busy": YELLOW, "idle": GREEN}.get(job, DIM)),
            (note, DIM),
        ])
    prefix = cfg.name_prefix + "-"
    for n in sorted(remote):
        if not n or not n.startswith(prefix) or n in matched:
            continue
        e = remote[n]
        rows.append([
            ("-", DIM),
            (n, None),
            ("-", DIM),
            (e.get("status", "?"), {"online": GREEN, "offline": RED}.get(e.get("status"), DIM)),
            ("busy" if e.get("busy") else "idle", DIM),
            ("registered on GitHub but no local directory", YELLOW),
        ])
    widths = [max(len(r[c][0]) for r in rows) for c in range(len(rows[0]))]
    print()
    for ri, r in enumerate(rows):
        cells = []
        for c, (text, color) in enumerate(r):
            cell = text.ljust(widths[c])
            if ri == 0:
                cell = paint(cell, BOLD)
            elif color:
                cell = paint(cell, color)
            cells.append(cell)
        print(("  " + "  ".join(cells)).rstrip())
    print()


def cmd_logs(cfg, idx, follow, daemon):
    if daemon:
        dc = DaemonController(cfg)
        if dc.mode == "systemd":
            cmd = ["journalctl", "--user", "-u", unit_name(cfg), "-n", "100", "--no-pager"]
            if follow:
                cmd.append("-f")
            os.execvp(cmd[0], cmd)
        logf = daemon_logfile(cfg)
        if not os.path.isfile(logf):
            raise Err("no supervisor log yet: {}".format(logf))
        cmd = ["tail", "-n", "100"] + (["-f"] if follow else []) + [logf]
        os.execvp(cmd[0], cmd)
    have = local_indices(cfg)
    if not have:
        raise Err("no runners provisioned; run `runnerctl up`")
    if idx is None:
        if len(have) == 1:
            idx = have[0]
        else:
            raise Err("multiple runners; pick one: runnerctl logs <idx>")
    if idx not in have:
        raise Err("no such runner: {}".format(idx))
    logf = runner_logfile(cfg, idx)
    if not os.path.isfile(logf):
        raise Err("no log yet for runner {}: {}".format(idx, logf))
    cmd = ["tail", "-n", "100"] + (["-f"] if follow else []) + [logf]
    os.execvp(cmd[0], cmd)


def cmd_config(cfg):
    dc = DaemonController(cfg)
    print("config file: {}".format(cfg.path))
    for key in ("name", "url", "count", "labels", "base_dir", "version",
                "name_prefix", "manager", "group", "dir_prefix"):
        val = getattr(cfg, key)
        shown = val if isinstance(val, str) else json.dumps(val)
        extra = "  (resolves to: {})".format(dc.mode) if key == "manager" and val == "auto" else ""
        print("  {} = {}{}".format(key, shown, extra))


# ---------------------------------------------------------------- entry point

def main(argv=None):
    ap = argparse.ArgumentParser(
        prog="runnerctl",
        description="Sudoless, config-driven pool manager for self-hosted "
                    "GitHub Actions runners. One supervisor service owns all "
                    "runner processes.")
    ap.add_argument("-c", "--config", metavar="FILE",
                    help="config file (default: ./runners.toml, "
                         "~/.config/runnerctl/runners.toml)")
    sub = ap.add_subparsers(dest="cmd", metavar="command")
    sub.required = True

    sub.add_parser("init", help="write a starter runners.toml here")
    p = sub.add_parser("up", help="converge the pool to the config "
                                  "(provision, register, supervise, prune)")
    p.add_argument("--count", type=int, metavar="N",
                   help="override the configured count for this run only")
    p.add_argument("--force", action="store_true",
                   help="prune surplus runners even if busy")
    p = sub.add_parser("scale", help="set count = N in the config and converge")
    p.add_argument("n", type=int)
    p.add_argument("--force", action="store_true")
    sub.add_parser("status", aliases=["ps"],
                   help="show pool status (supervisor + runners + GitHub)")
    p = sub.add_parser("down", help="stop the supervisor and all runners; "
                                    "keep registrations")
    p.add_argument("--force", action="store_true", help="stop even busy runners")
    p = sub.add_parser("rm", help="deregister and delete runners")
    p.add_argument("idx", nargs="*", type=int)
    p.add_argument("--all", action="store_true")
    p.add_argument("--force", action="store_true")
    for name, hlp in (("start", "start runners (clear their stopped mark)"),
                      ("stop", "stop runners (kept registered, not respawned)"),
                      ("restart", "restart runners")):
        p = sub.add_parser(name, help=hlp)
        p.add_argument("idx", nargs="*", type=int)
        if name in ("stop", "restart"):
            p.add_argument("--force", action="store_true",
                           help="proceed even if the runner is busy")
    p = sub.add_parser("logs", help="show a runner's (or the supervisor's) logs")
    p.add_argument("idx", nargs="?", type=int)
    p.add_argument("-f", "--follow", action="store_true")
    p.add_argument("--daemon", action="store_true", help="supervisor log instead")
    sub.add_parser("config", help="print the resolved configuration")
    sub.add_parser("daemon", help="run the supervisor in the foreground "
                                  "(normally started for you by `up`)")

    args = ap.parse_args(argv)
    try:
        if args.cmd == "init":
            cmd_init(args.config or "runners.toml")
            return 0
        cfg = load_config(find_config(args.config))
        if args.cmd == "up":
            cmd_up(cfg, args.count, args.force)
        elif args.cmd == "scale":
            cmd_scale(cfg, args.n, args.force)
        elif args.cmd in ("status", "ps"):
            cmd_status(cfg)
        elif args.cmd == "down":
            cmd_down(cfg, args.force)
        elif args.cmd == "rm":
            cmd_rm(cfg, args.idx, args.all, args.force)
        elif args.cmd in ("start", "stop", "restart"):
            cmd_svc(cfg, args.cmd, args.idx, getattr(args, "force", False))
        elif args.cmd == "logs":
            cmd_logs(cfg, args.idx, args.follow, args.daemon)
        elif args.cmd == "config":
            cmd_config(cfg)
        elif args.cmd == "daemon":
            Supervisor(cfg).run()
    except Err as e:
        print(paint("error:", RED) + " " + str(e), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print()
        return 130
    return 0


if __name__ == "__main__":
    sys.exit(main())

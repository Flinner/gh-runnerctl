# runnerctl configuration — the config file IS the interface:
# edit it, then `runnerctl up` (full converge, does GitHub registration work)
# or `runnerctl reload` (soft apply to running supervisors, no GitHub work).
#
# One file = one instance; it may define any number of pools, on this machine
# or on other machines over passwordless ssh. GitHub auth stays on THIS
# machine: remote hosts only ever receive short-lived registration/removal
# tokens, piped over ssh stdin.

config_version = "1.0"                  # schema: major mismatch = refused, minor = warning
name = "default"                        # instance name -> runnerctl-<name>-<machine>.service
check_updates = "ask"                   # after `status`: ask | always | never (never installs)

[defaults]                              # keys shared by every pool below
url = "https://github.com/YOUR-ORG"    # org URL (runners serve all repos) or a repo URL
base_dir = "~/gh-runners"               # runners live in <base_dir>/<dir_prefix><N>
version = "latest"                      # runner release, e.g. "2.335.1", or "latest"
manager = "auto"                        # per-machine supervisor hosting: auto | systemd | nohup
                                        # (override per pool; pools on one machine must agree)

[pool.head]
host = "user@acclhead1.example.org"     # ssh destination (alias or user@host); "" = this machine
count = 4
labels = ["self-hosted", "linux", "x64"]

[pool.gpu]
host = "gpunode"
count = 2
labels = ["self-hosted", "linux", "x64", "gpu", "cuda"]
# every [defaults] key can be overridden per pool:
# url = "https://github.com/YOUR-ORG/special-repo"
# group = "gpu-runners"                 # org runner group

# ---------------------------------------------------------------------------
# Notes
#
# - Remote pools: `runnerctl up` copies this script + this config to the host
#   (over plain ssh, no scp needed) and runs a supervisor there. Your GitHub
#   token never leaves this machine.
# - Shared home directories (clusters) are fine: supervisor state and systemd
#   units are scoped per machine, and units carry ConditionHost so a host
#   never boots another host's supervisor. Just keep dir_prefix distinct
#   between pools (the default — the pool name — already is).
# - Runner directories: dir_prefix defaults to the pool name ("head1",
#   "gpu2"). A single anonymous [pool] (no [pool.<name>] tables) is the pool
#   "default" with dir_prefix "runner" — set dir_prefix = "actions" there to
#   adopt an existing hand-made actions1..N layout.
# - GitHub-side names: <name_prefix>-<pool>-<N>; name_prefix defaults to the
#   pool's host alias (or this hostname for local pools).
# - CLI addressing: `runnerctl stop gpu/2`, `runnerctl logs gpu/2 -f`,
#   `runnerctl rm gpu` (whole pool), or a bare index in single-pool files.
# - Preview any mutating command with --dry-run (-n): `runnerctl up -n`.

# runnerctl configuration — the config file IS the interface:
# edit it, then `runnerctl up` (full converge, does GitHub registration work)
# or `runnerctl reload` (soft apply to the running supervisor, no GitHub work).
#
# One file = one supervisor service; it may define any number of pools.

name = "default"                        # instance name -> runnerctl-<name>.service
manager = "auto"                        # how the supervisor is hosted: auto | systemd | nohup

[defaults]                              # keys shared by every pool below
url = "https://github.com/YOUR-ORG"    # org URL (runners serve all repos) or a repo URL
base_dir = "~/actions-runner"           # runners live in <base_dir>/<dir_prefix><N>
version = "latest"                      # runner release, e.g. "2.335.1", or "latest"
name_prefix = ""                        # GitHub-side name prefix; default: this hostname

[pool.main]
count = 4
labels = ["self-hosted", "linux", "x64"]

[pool.gpu]
count = 2
labels = ["self-hosted", "linux", "x64", "gpu", "cuda"]
# every [defaults] key can be overridden per pool:
# url = "https://github.com/YOUR-ORG/special-repo"
# group = "gpu-runners"                 # org runner group

# ---------------------------------------------------------------------------
# Notes
#
# - Runner directories: dir_prefix defaults to the pool name ("main1", "gpu2").
#   A single anonymous [pool] (no [pool.<name>] tables) is the pool "default"
#   with dir_prefix "runner" — set dir_prefix = "actions" there to adopt an
#   existing hand-made actions1..N layout.
# - GitHub-side names: <name_prefix>-<pool>-<N> ("host-gpu-2"); the pool
#   "default" uses plain <name_prefix>-<N>.
# - CLI addressing: `runnerctl stop gpu/2`, `runnerctl logs gpu/2`,
#   `runnerctl rm gpu` (whole pool), or a bare index in single-pool files.
# - Preview any mutating command with --dry-run (-n): `runnerctl up -n`.
